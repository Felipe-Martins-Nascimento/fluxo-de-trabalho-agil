            <button class="btn-add"
                    onclick="addCard('positivo')">

                ➕ Novo Card

            </button>
        </div>

        <div class="column negative-column"
             ondrop="drop(event)"
             ondragover="allowDrop(event)"
             data-status="negativo">

            <div class="column-header">

                <h2 class="column-title">
                    Negativos
                </h2>
            </div>

            
            
            <div class="cards" id="negativo"></div>
            <button class="btn-add"
                    onclick="addCard('negativo')">

                ➕ Novo Card

            </button>
        </div>

        <div class="column suggestion-column"
             ondrop="drop(event)"
             ondragover="allowDrop(event)"
             data-status="sugestao">

            <div class="column-header">

                <h2 class="column-title">
                    Melhorias
                </h2>

            </div>
         
            <div class="cards" id="sugestao"></div>
            <button class="btn-add"
                    onclick="addCard('sugestao')">

                ➕ Novo Card

            </button>
        </div>

    </div>

    <div class="ia-section">

        <div class="ia-header">

            <h2>
                🤖 Análise Inteligente da Sprint
            </h2>

        </div>

        <div id="resultadoIA"
             class="ia-result">

            <div class="ia-placeholder">

                Adicione feedbacks positivos, negativos e sugestões para gerar uma análise completa da Sprint.

            </div>

        </div>

    </div>
    <div id="toast"></div>
</div>

<script>
    const API =
        "http://localhost:5228/api/retro";
    let cardId = 0;
    let sprintAtualId = 0;

    function addCard(status) {

        const container = document.getElementById(status);

        const id = "card-" + cardId++;

        const div = document.createElement("div");

        div.className = "card";
        div.draggable = true;
        div.id = id;

        div.ondragstart = drag;

        div.innerHTML = `

            <div class="card-top">

                <div class="card-voting-inline">

                    <button onclick="votar(this,1)">
                        👍
                    </button>

                    <span class="vote-count">
                        0
                    </span>

                    <button onclick="votar(this,-1)">
                        👎
                    </button>

                </div>

                <button class="delete-card"
                        onclick="removerCard(this)">
                    🗑️
                </button>

            </div>

                <textarea
            class="card-text"
            placeholder="Digite seu feedback aqui..."></textarea>

        `;

        container.appendChild(div);

        div
            .querySelector("textarea")
            .focus();

        atualizarContadores();
    }

    function allowDrop(ev) {

        ev.preventDefault();

        ev.currentTarget.classList.add(
            "drag-over"
        );
    }

    function drag(ev) {

        ev.target.classList.add(
            "dragging"
        );

        ev.dataTransfer.setData(
            "text",
            ev.target.id
        );
    }

    document.addEventListener(
        "dragend",
        function () {

            document
                .querySelectorAll(".card")
                .forEach(x =>
                    x.classList.remove(
                        "dragging"
                    ));

        });

    function drop(ev) {

        ev.preventDefault();

        ev.currentTarget.classList.remove(
            "drag-over"
        );

        const id =
            ev.dataTransfer.getData("text");

        const card =
            document.getElementById(id);

        ev.currentTarget
            .querySelector(".cards")
            .appendChild(card);

        atualizarContadores();
    }

    async function salvarSprint() {

        const cards = [];

        document.querySelectorAll("#positivo .card")
            .forEach(card => {

                cards.push({
                    tipo: "positivo",
                    texto: card.querySelector("textarea").value,
                    votos: parseInt(
                        card.querySelector(".vote-count").innerText
                    ) || 0
                });

            });

        document.querySelectorAll("#negativo .card")
            .forEach(card => {

                cards.push({
                    tipo: "negativo",
                    texto: card.querySelector("textarea").value,
                    votos: parseInt(
                        card.querySelector(".vote-count").innerText
                    ) || 0
                });

            });

        document.querySelectorAll("#sugestao .card")
            .forEach(card => {

                cards.push({
                    tipo: "sugestao",
                    texto: card.querySelector("textarea").value,
                    votos: parseInt(
                        card.querySelector(".vote-count").innerText
                    ) || 0
                });

            });

        const payload = {

            id: sprintAtualId,

            nomeSprint:
                document.getElementById("nomeSprint").value,

            cards
        };

        const metodo = "POST";

        const url = API;

        try {

            const response =
                await fetch(url, {

                    method: metodo,

                    headers: {
                        "Content-Type": "application/json"
                    },

                    body: JSON.stringify(payload)
                });

            if (!response.ok)
                throw await response.text();

            const resultado =
                await response.json();

            sprintAtualId =
                resultado.id;

            showToast(
                "Sprint salva com sucesso",
                "success"
            );

            await carregarSprints();

            document.getElementById(
                "cmbSprint"
            ).value = sprintAtualId;
        }
        catch (err) {

            console.error(err);

            showToast(
                "Erro ao salvar sprint",
                "error"
            );
        }
    }

    function getCards(col) {

        return [...document.querySelectorAll("#" + col + " .card textarea")]
            .map(x => x.value);
    }

    function novaSprint() {

        sprintAtualId = 0;

        document
            .getElementById("nomeSprint")
            .value = "";

        document
            .getElementById("txtPesquisar")
            .value = "";

        document
            .getElementById("resultadoIA")
            .innerHTML = `

    <div class="ia-empty">
        <p>
            Adicione feedbacks positivos,
            negativos e sugestões para
            gerar uma análise completa
            da Sprint.
        </p>

    </div>

    `;

        ["positivo", "negativo", "sugestao"]
            .forEach(x => {

                document
                    .getElementById(x)
                    .innerHTML = "";

            });

        atualizarContadores();

        showToast(
            "Nova Sprint criada",
            "success"
        );
    }

    function exportarPDF() {

        const { jsPDF } = window.jspdf;
        const doc = new jsPDF("p", "mm", "a4");

        const valor = v =>
            v && v.toString().trim() ? v : "-";

        const getCards = (selector) => {
            return [...document.querySelectorAll(selector)]
                .map(c => ({
                    texto: (c.querySelector("textarea")?.value || "").trim(),
                    votos: parseInt(c.querySelector(".vote-count")?.innerText) || 0
                }));
        };

        const positivos = getCards("#positivo .card");
        const negativos = getCards("#negativo .card");
        const sugestoes = getCards("#sugestao .card");

        const positivosTotal = positivos.reduce((acc, c) => acc + (1 + (c.votos || 0)), 0);
        const negativosTotal = negativos.reduce((acc, c) => acc + (1 + (c.votos || 0)), 0);
        const sugestoesTotal = sugestoes.reduce((acc, c) => acc + (1 + (c.votos || 0)), 0);

        const totalCards =
            positivosTotal +
            negativosTotal +
            sugestoesTotal;

        let y = 15;

        doc.setFillColor(15, 23, 42);
        doc.rect(0, 0, 210, 25, "F");

        doc.setTextColor(255);
        doc.setFontSize(20);
        doc.text("SPRINT RETROSPECTIVE", 14, 16);

        doc.setFontSize(10);
        doc.text(valor(document.getElementById("nomeSprint").value), 14, 22);

        y = 35;

        function titulo(texto, cor) {
            doc.setFillColor(...cor);
            doc.rect(10, y - 5, 190, 8, "F");

            doc.setTextColor(255);
            doc.setFontSize(11);
            doc.text(texto, 13, y);

            doc.setTextColor(0);
            y += 12;
        }

        function linha(label, value) {
            doc.setFontSize(10);
            doc.setFont(undefined, "bold");
            doc.text(label + ":", 12, y);

            doc.setFont(undefined, "normal");
            doc.text(String(value), 70, y);

            y += 6;
        }

        function cardItem(card) {

            const texto = card.texto.length > 0 ? card.texto : "-";
            const votos = card.votos || 0;

            doc.setFontSize(10);
            doc.setFont(undefined, "normal");

            doc.text(`• ${votos} - ${texto}`, 12, y);

            y += 6;

            if (y > 270) {
                doc.addPage();
                y = 20;
            }
        }

        titulo("MÉTRICAS", [100, 116, 139]);
        linha("Pontos Positivos", positivosTotal);
        linha("Pontos Negativos", negativosTotal);
        linha("Melhorias", sugestoesTotal);
        linha("Total Cards", totalCards);

        y += 4;

        titulo("POSITIVOS", [16, 163, 74]);
        positivos.forEach(cardItem);

        titulo("NEGATIVOS", [220, 38, 38]);
        negativos.forEach(cardItem);

        titulo("MELHORIAS", [37, 99, 235]);
        sugestoes.forEach(cardItem);

        doc.save(`SprintRetrospective_${valor(document.getElementById("nomeSprint").value)}.pdf`);
    }

    function exportarExcel() {

        const wb = XLSX.utils.book_new();

        const valor = v =>
            v && v.toString().trim() ? v : "-";

        const getCards = (selector) => {
            return [...document.querySelectorAll(selector)]
                .map(c => ({
                    texto: c.querySelector("textarea")?.value || "",
                    votos: parseInt(c.querySelector(".vote-count")?.innerText) || 0
                }));
        };

        const positivos = getCards("#positivo .card");
        const negativos = getCards("#negativo .card");
        const sugestoes = getCards("#sugestao .card");

        const positivosTotal = positivos.reduce((a, c) => a + (1 + (c.votos || 0)), 0);
        const negativosTotal = negativos.reduce((a, c) => a + (1 + (c.votos || 0)), 0);
        const sugestoesTotal = sugestoes.reduce((a, c) => a + (1 + (c.votos || 0)), 0);

        const totalCards =
            positivosTotal +
            negativosTotal +
            sugestoesTotal;

        const dados = [];

        dados.push(["SPRINT RETROSPECTIVE"]);
        dados.push([]);
        dados.push(["Nome Sprint", valor(document.getElementById("nomeSprint").value)]);
        dados.push([]);

        dados.push(["MÉTRICAS"]);
        dados.push(["Pontos Positivos", positivosTotal]);
        dados.push(["Pontos Negativos", negativosTotal]);
        dados.push(["Melhorias", sugestoesTotal]);
        dados.push(["Total Cards", totalCards]);
        dados.push([]);

        dados.push(["POSITIVOS"]);
        positivos.forEach(x =>
            dados.push([`• ${x.votos} - ${x.texto || "-"}`])
        );
        dados.push([]);

        dados.push(["NEGATIVOS"]);
        negativos.forEach(x =>
            dados.push([`• ${x.votos} - ${x.texto || "-"}`])
        );
        dados.push([]);

        dados.push(["MELHORIAS"]);
        sugestoes.forEach(x =>
            dados.push([`• ${x.votos} - ${x.texto || "-"}`])
        );

        const ws = XLSX.utils.aoa_to_sheet(dados);

        ws["!cols"] = [{ wch: 120 }];

        const styles = {
            POSITIVOS: { fill: "16A34A", font: "FFFFFF" },
            NEGATIVOS: { fill: "DC2626", font: "FFFFFF" },
            MELHORIAS: { fill: "2563EB", font: "FFFFFF" },
            MÉTRICAS: { fill: "334155", font: "FFFFFF" }
        };

        Object.keys(ws).forEach(cell => {

            if (cell.startsWith("!")) return;

            const value = ws[cell].v;

            if (styles[value]) {
                ws[cell].s = {
                    font: { bold: true, color: { rgb: styles[value].font } },
                    fill: { fgColor: { rgb: styles[value].fill } }
                };
            }
        });

        XLSX.utils.book_append_sheet(wb, ws, "Sprint");

        XLSX.writeFile(
            wb,
            `SprintRetrospective_${valor(document.getElementById("nomeSprint").value)}.xlsx`
        );
    }

    function carregarSprints() {
        fetch(API)
            .then(r => r.json())
            .then(data => {

                const cmb = document.getElementById("cmbSprint");
                cmb.innerHTML = `<option value="">Nova Sprint</option>`;

                data.forEach(x => {
                    cmb.innerHTML += `<option value="${x.id}">${x.nomeSprint}</option>`;
                });
            });
    }

    async function carregarSprint(id) {

        if (!id) {

            novaSprint();
            return;
        }

        try {

            const response =
                await fetch(`${API}/${id}`);

            const data =
                await response.json();

            sprintAtualId =
                data.id;

            document.getElementById(
                "nomeSprint"
            ).value =
                data.nomeSprint || "";

            preencher(
                "positivo",
                data.cards.filter(x =>
                    x.tipo === "positivo")
            );

            preencher(
                "negativo",
                data.cards.filter(x =>
                    x.tipo === "negativo")
            );

            preencher(
                "sugestao",
                data.cards.filter(x =>
                    x.tipo === "sugestao")
            );

            atualizarContadores();

            showToast(
                "Sprint carregada",
                "success"
            );
        }
        catch (e) {

            console.error(e);

            showToast(
                "Erro ao carregar Sprint",
                "error"
            );
        }
    }

    function preencher(col, lista) {

        const container =
            document.getElementById(col);

        container.innerHTML = "";

        lista.forEach(card => {

            const div =
                document.createElement("div");

            div.className = "card";

            div.draggable = true;

            div.ondragstart = drag;

            div.id =
                "card-" + cardId++;

            div.innerHTML = `

                <div class="card-top">

                    <div class="card-voting-inline">

                        <button onclick="votar(this,1)">
                            👍
                        </button>

                        <span class="vote-count">
                            ${card.votos || 0}
                        </span>

                        <button onclick="votar(this,-1)">
                            👎
                        </button>

                    </div>

                    <button class="delete-card"
                            onclick="removerCard(this)">
                        🗑️
                    </button>

                </div>

                <textarea
                class="card-text">${card.texto || ""}</textarea>

            `;

            container.appendChild(div);
        });
    }

    window.onload = carregarSprints;

    async function gerarInsightsIA() {
        document
            .getElementById("resultadoIA")
            .scrollIntoView({
                behavior: "smooth",
                block: "start"
            });
    const positivos =
        getCards("positivo");

    const negativos =
        getCards("negativo");

    const sugestoes =
        getCards("sugestao");

    document.getElementById(
        "resultadoIA"
    ).innerHTML = `
        <div class="loading-ai">
            🤖 Analisando Sprint...
        </div>
    `;

    try {

        const response =
                await fetch(
                    `${API}/gerar-insights`,
                {
                    method: "POST",
                    headers: {
                        "Content-Type":
                            "application/json"
                    },
                    body: JSON.stringify({
                        positivos,
                        negativos,
                        sugestoes
                    })
                });

        const texto =
            await response.text();

        document.getElementById(
            "resultadoIA"
        ).innerHTML = texto;
    }
    catch {

        document.getElementById(
            "resultadoIA"
        ).innerHTML = `
            <div class="erro-ai">
                Erro ao gerar insights.
            </div>
        `;
    }
}

    function atualizarContadores() {

        const cardsPositivos =
            document.querySelectorAll(
                "#positivo .card"
            );

        let positivos = 0;

        cardsPositivos.forEach(card => {

            positivos += 1;

            const votos =
                parseInt(
                    card.querySelector(
                        ".vote-count"
                    ).innerText
                ) || 0;

            positivos += votos;
        });

        const cardsNegativos =
            document.querySelectorAll(
                "#negativo .card"
            );

        let negativos = 0;

        cardsNegativos.forEach(card => {

            negativos += 1;

            const votos =
                parseInt(
                    card.querySelector(
                        ".vote-count"
                    ).innerText
                ) || 0;

            negativos += votos;
        });

        const sugestoes =
            document.querySelectorAll(
                "#sugestao .card"
            );

        let sugestoesTotal = 0;

        sugestoes.forEach(card => {

            sugestoesTotal += 1;

            const votos =
                parseInt(
                    card.querySelector(
                        ".vote-count"
                    ).innerText
                ) || 0;

            sugestoesTotal += votos;
        });

        document.getElementById(
            "totalPositivos"
        ).innerText = positivos;

        document.getElementById(
            "totalNegativos"
        ).innerText = negativos;

        document.getElementById(
            "totalSugestoes"
        ).innerText = sugestoesTotal;

        document.getElementById(
            "totalCards"
        ).innerText = positivos + negativos + sugestoesTotal;
    }

    function filtrarCards() {

        const termo =
            document.getElementById(
                "txtPesquisar"
            ).value.toLowerCase();

        document
            .querySelectorAll(".card")
            .forEach(card => {

                    const texto =
                        card.querySelector("textarea")
                            ?.value
                            .toLowerCase() || "";

                card.style.display =
                    texto.includes(termo)
                    ? ""
                    : "none";

            });

    }

    function removerCard(btn) {

        btn.closest(".card").remove();

        atualizarContadores();

    }

    function showToast(msg, tipo = "info") {

        const toast =
            document.createElement("div");

        toast.className =
            `toast-item toast-${tipo}`;

        toast.innerHTML = msg;

        document
            .getElementById("toast")
            .appendChild(toast);

        setTimeout(() => {

            toast.remove();

        }, 3000);
    }

    function votar(btn, valor) {

        const span =
            btn.parentElement
                .querySelector(".vote-count");

        let atual =
            parseInt(span.innerText);

        atual += valor;

        if (atual < 0)
            atual = 0;

        span.innerText = atual;
        atualizarContadores();
    }
</script>
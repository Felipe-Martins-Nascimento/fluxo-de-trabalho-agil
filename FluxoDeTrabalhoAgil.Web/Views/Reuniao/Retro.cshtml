        </div>

    </div>

    <div class="retro-metrics">

        <div class="metric-card positive">
            <span id="totalPositivos">0</span>
            <small>Pontos Positivos</small>
        </div>

        <div class="metric-card negative">
            <span id="totalNegativos">0</span>
            <small>Pontos Negativos</small>
        </div>

        <div class="metric-card suggestion">
            <span id="totalSugestoes">0</span>
            <small>Melhorias</small>
        </div>

        <div class="metric-card total">
            <span id="totalCards">0</span>

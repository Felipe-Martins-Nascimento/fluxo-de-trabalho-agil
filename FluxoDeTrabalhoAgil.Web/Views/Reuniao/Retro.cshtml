            💾 Salvar
        </button>

        <button class="btn btn-danger"
                onclick="exportarPDF()">
            📄 PDF
        </button>

        <button class="btn btn-success"
                onclick="exportarExcel()">
            📊 Excel
        </button>

        <button class="btn btn-ai"
                onclick="gerarInsightsIA()">
            🤖 Gerar Insights IA
        </button>

    </div>

    <div class="retro-search">

        <label>
            Pesquisar feedbacks
        </label>

        <div class="search-box">

            <span>
                🔍
            </span>

            <input type="text"
                   id="txtPesquisar"
                   placeholder="Pesquisar cards..."

@{
    Layout = "_Layout";
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx-js-style/dist/xlsx.bundle.js"></script>

<style>
    body {
        background: radial-gradient(circle at top left, rgba(59,130,246,.08), transparent 25%), #f8fafc;
        font-family: 'Segoe UI', sans-serif;
    }

    .review-wrapper {
        padding: 28px;
    }

    .topbar-review {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 26px;
        background: #fff;
        border-radius: 28px;
        padding: 26px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 15px 35px rgba(15,23,42,.05);
    }

    .topbar-left {
        display: flex;
        flex-direction: column;
        gap: 18px;
        flex: 1;
        min-width: 340px;
    }

    .topbar-title h1 {
        margin: 0;
        font-size: 34px;
        font-weight: 800;
        color: #0f172a;
    }

    .topbar-title p {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 14px;
        line-height: 1.6;
    }

    .sprint-actions {
        display: flex;
        align-items: end;
        gap: 16px;
        flex-wrap: wrap;
    }

    .sprint-select-box {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .sprint-select-box label {
            font-size: 13px;
            font-weight: 700;
            color: #475569;
        }

    .review-select {
        min-width: 300px;
        height: 52px;
        border-radius: 16px;
        border: 1px solid #dbeafe;
        padding: 0 16px;
        font-size: 14px;
        font-weight: 700;
        background: #f8fbff;
        color: #1e293b;
        outline: none;
        transition: .2s;
    }

        .review-select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59,130,246,.12);
        }

    .topbar-buttons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .export-buttons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-review {
        border: none;
        border-radius: 16px;
        padding: 13px 22px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s;
    }

        .btn-review:hover {
            transform: translateY(-3px);
        }

    .btn-primary-review {
        background: linear-gradient(135deg,#2563eb,#3b82f6);
        color: #fff;
        box-shadow: 0 12px 24px rgba(37,99,235,.25);
    }

    .btn-secondary-review {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #2563eb;
        box-shadow: 0 8px 20px rgba(37,99,235,.12);
    }

    .btn-pdf-review {
        background: #fff7ed;
        border: 1px solid #fdba74;
        color: #ea580c;
        box-shadow: 0 8px 20px rgba(234,88,12,.12);
    }

    .btn-success-review {
        background: linear-gradient(135deg,#059669,#10b981);
        color: white;
        box-shadow: 0 10px 22px rgba(16,185,129,.20);
    }

    .review-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
        gap: 18px;
        margin-bottom: 22px;
    }

    .metric-card {
        background: #fff;
        border-radius: 24px;
        padding: 18px 20px;
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
        transition: .25s;
        box-shadow: 0 8px 24px rgba(15,23,42,.04);
    }

        .metric-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(15,23,42,.08);
        }

        .metric-card::before {
            content: "";
            position: absolute;
            inset: 0 0 auto 0;
            height: 4px;
            background: linear-gradient(90deg,#2563eb,#60a5fa);
        }

    .metric-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
    }

    .metric-label {
        font-size: 14px;
        font-weight: 800;
        color: #0f172a;
    }

    .metric-icon {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        background: #eff6ff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2563eb;
        font-size: 15px;
        font-weight: 700;
    }

    .metric-input {
        width: 100%;
        border: 1px solid #e2e8f0;
        outline: none;
        background: #f8fafc;
        border-radius: 16px;
        padding: 15px;
        font-size: 15px;
        font-weight: 600;
        transition: .2s;
        color: #0f172a;
    }

        .metric-input:focus {
            border-color: #3b82f6;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(59,130,246,.10);
        }

    .metric-sub {
        margin-top: 10px;
        color: #94a3b8;
        font-size: 12px;
    }

    .review-layout {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .review-card {
        background: #fff;
        border-radius: 28px;
        padding: 26px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 28px rgba(15,23,42,.04);
    }

    .review-card-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        gap: 10px;
        flex-wrap: wrap;
    }

        .review-card-title h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
        }

    .input-review,
    .textarea-review,
    .select-review {
        width: 100%;
        border-radius: 16px;
        border: 1px solid #dbeafe;
        background: #f8fbff;
        padding: 14px 16px;
        font-size: 14px;
        outline: none;
        transition: .2s;
    }

        .input-review:focus,
        .textarea-review:focus,
        .select-review:focus {
            border-color: #3b82f6;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(59,130,246,.10);
        }

    .textarea-review {
        min-height: 140px;
        resize: vertical;
    }

    .review-field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .review-field label {
            font-size: 13px;
            font-weight: 700;
            color: #334155;
        }

    .deliveries-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px;
    }

    @@media(max-width:1100px) {

        .deliveries-layout {
            grid-template-columns: 1fr;
        }
    }

    .task-box {
        background: linear-gradient(180deg,#ffffff,#f8fbff);
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 20px;
    }

    .task-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 14px;
        align-items: end;
    }

    @@media(max-width:800px) {

        .task-grid {
            grid-template-columns: 1fr;
        }
    }

    .task-error {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 4px rgba(239,68,68,.08);
    }

    .btn-add-task {
        margin-top: 18px;
        background: linear-gradient(135deg,#2563eb,#3b82f6);
        color: white;
        border: none;
        border-radius: 16px;
        padding: 14px 18px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s;
        width: 100%;
    }

        .btn-add-task:hover {
            transform: translateY(-3px);
        }

    .delivery-list {
        background: linear-gradient(180deg,#ffffff,#f8fbff);
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 20px;
        min-height: 100%;
    }

    .delivery-item {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 16px;
        margin-bottom: 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

    .delivery-status {
        padding: 7px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .status-ok {
        background: #dcfce7;
        color: #15803d;
    }

    .status-partial {
        background: #fef3c7;
        color: #b45309;
    }

    .status-no {
        background: #fee2e2;
        color: #b91c1c;
    }

    .delivery-summary {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 14px;
        margin-top: 18px;
    }

    .delivery-summary-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 16px;
        text-align: center;
    }

        .delivery-summary-card strong {
            display: block;
            font-size: 24px;
            margin-bottom: 6px;
            color: #0f172a;
        }

        .delivery-summary-card span {
            color: #64748b;
            font-size: 13px;
            font-weight: 700;
        }

    .double-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px;
    }

    @@media(max-width:1100px) {

        .double-grid {
            grid-template-columns: 1fr;
        }
    }

    .compact-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 14px;
    }

    .mini-card {
        background: linear-gradient(180deg,#ffffff,#f8fbff);
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 14px;
    }

        .mini-card label {
            display: block;
            margin-bottom: 10px;
            font-size: 13px;
            font-weight: 700;
            color: #475569;
        }

        .mini-card input {
            width: 100%;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            background: #fff;
            padding: 12px;
            outline: none;
            font-size: 14px;
            font-weight: 600;
        }

    .feedback-section {
        margin-top: 4px;
    }

    .feedback-title {
        font-size: 22px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 22px;
    }

    .feedback-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px;
    }

    @@media(max-width:1100px) {

        .feedback-grid {
            grid-template-columns: 1fr;
        }
    }

    .feedback-column {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .review-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: linear-gradient(135deg,#dbeafe,#eff6ff);
        color: #2563eb;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .8px;
        margin-bottom: 12px;
    }

    .review-main-title {
        margin: 0;
        font-size: 42px;
        font-weight: 900;
        line-height: 1;
        color: #0f172a;
        letter-spacing: -1.5px;
    }

    #listaEntregasRealizadas {
        max-height: 280px;
        overflow-y: auto;
        padding-right: 6px;
    }

        #listaEntregasRealizadas::-webkit-scrollbar {
            width: 8px;
        }

        #listaEntregasRealizadas::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

            #listaEntregasRealizadas::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }

    .summary-success {
        background: #ecfdf5;
        border: 1px solid #86efac;
    }

    .summary-warning {
        background: #fffbeb;
        border: 1px solid #fde68a;
    }

    .summary-danger {
        background: #fef2f2;
        border: 1px solid #fca5a5;
    }

    .btn-remove-delivery {
        width: 34px;
        height: 34px;
        border: none;
        border-radius: 12px;
        background: #fee2e2;
        color: #dc2626;
        cursor: pointer;
        font-weight: 800;
        transition: .2s;
    }

        .btn-remove-delivery:hover {
            background: #fecaca;
            transform: scale(1.05);
        }

    .sprint-name-box {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 320px;
    }

    .sprint-name-box label {
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
    }

    .input-error {
        border-color: #ef4444 !important;
        background: #fef2f2 !important;
        animation: shake .25s linear;
    }

    @@keyframes shake {

        0% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-4px);
        }

        50% {
            transform: translateX(4px);
        }

        75% {
            transform: translateX(-4px);
        }

        100% {
            transform: translateX(0);
        }
    }

    .feedback-toast {
        position: fixed;
        right: 25px;
        top: 25px;
        z-index: 99999;
        background: #0f172a;
        color: white;
        padding: 14px 20px;
        border-radius: 14px;
        font-weight: 600;
        box-shadow: 0 15px 35px rgba(0,0,0,.18);
        animation: fadeToast .3s;
    }

    @@keyframes fadeToast {

        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="review-wrapper">

    <div class="topbar-review">

        <div class="topbar-left">

            <div class="topbar-title">

                <div class="review-badge">
                    Sprint Management
                </div>

                <h1 class="review-main-title">
                    Sprint Review
                </h1>

                <p>
                    Revisão completa das entregas,
                    métricas, bugs, feedbacks e resultados da Sprint.
                </p>

            </div>

            <div class="sprint-actions">

                <div class="sprint-select-box">

                    <label>
                        Selecionar Sprint
                    </label>

                    <select id="cmbSprint"
                            class="review-select"
                            onchange="carregarSprint(this.value)">

                        <option value="">
                            Nova Sprint
                        </option>

                    </select>

                </div>

                <div class="topbar-buttons">

                    <button class="btn-review btn-secondary-review"
                            onclick="novaSprint()">
                        🚀 Nova Sprint
                    </button>

                    <button class="btn-review btn-primary-review"
                            onclick="salvarSprint()">

                        💾 Salvar Sprint

                    </button>

                    <button class="btn-review btn-secondary-review"
                            onclick="exportarPDF()">
                        📄 Exportar PDF
                    </button>

                    <button class="btn-review btn-success-review"
                            onclick="exportarExcel()">
                        📊 Exportar Excel
                    </button>

                </div>

            </div>

            <div class="sprint-name-box">

                <label>
                    Nome da Sprint
                </label>

                <input id="nomeSprint"
                       class="input-review"
                       placeholder="Ex: Sprint 15 - Integração ERP">

            </div>
        </div>

    </div>

    <div class="review-grid">

        <div class="metric-card">

            <div class="metric-top">

                <span class="metric-label">
                    Tasks Totais
                </span>

                <div class="metric-icon">
                    ✓
                </div>

            </div>

            <input id="tasksTotais"
                   class="metric-input"
                   placeholder="Digite o total de tasks">

            <div class="metric-sub">
                Quantidade total planejada para a Sprint
            </div>

        </div>

        <div class="metric-card">

            <div class="metric-top">

                <span class="metric-label">
                    Tasks Concluídas
                </span>

                <div class="metric-icon">
                    ✓
                </div>

            </div>

            <input id="tasksConcluidas"
                   class="metric-input"
                   placeholder="Digite as tasks concluídas">

            <div class="metric-sub">
                Tasks entregues com sucesso
            </div>

        </div>

        <div class="metric-card">

            <div class="metric-top">

                <span class="metric-label">
                    Tasks Não Concluídas
                </span>

                <div class="metric-icon">
                    !
                </div>

            </div>

            <input id="tasksNaoConcluidas"
                   class="metric-input"
                   placeholder="Digite as tasks pendentes">

            <div class="metric-sub">
                Tasks não finalizadas
            </div>

        </div>

        <div class="metric-card">

            <div class="metric-top">

                <span class="metric-label">
                    Velocity Entregue
                </span>

                <div class="metric-icon">
                    ↗
                </div>

            </div>

            <input id="velocityEntregue"
                   class="metric-input"
                   placeholder="Digite o velocity entregue">

            <div class="metric-sub">
                Story points concluídos
            </div>

        </div>

        <div class="metric-card">

            <div class="metric-top">

                <span class="metric-label">
                    Velocity Não Entregue
                </span>

                <div class="metric-icon">
                    ↘
                </div>

            </div>

            <input id="velocityNaoEntregue"
                   class="metric-input"
                   placeholder="Digite o velocity pendente">

            <div class="metric-sub">
                Story points não entregues
            </div>

        </div>

        <div class="metric-card">

            <div class="metric-top">

                <span class="metric-label">
                    Participantes
                </span>

                <div class="metric-icon">
                    👥
                </div>

            </div>

            <input id="participantes"
                   class="metric-input"
                   placeholder="Digite os participantes">

            <div class="metric-sub">
                Pessoas presentes na review
            </div>

        </div>

    </div>

    <div class="review-card">

        <div class="review-card-title">

            <h2>
                📝 Entregas Realizadas
            </h2>

        </div>

        <div class="deliveries-layout">

            <div class="task-box">

                <div class="task-grid">

                    <div class="review-field">

                        <label>
                            Nome da Entrega
                        </label>

                        <input id="nomeEntrega"
                               class="input-review"
                               placeholder="Digite o nome da entrega">

                    </div>

                    <div class="review-field">

                        <label>
                            Status
                        </label>

                        <select id="statusEntrega"
                                class="select-review">

                            <option>
                                ✅ Entregue
                            </option>

                            <option>
                                ⚠ Parcial
                            </option>

                            <option>
                                ❌ Não Entregue
                            </option>

                        </select>

                    </div>

                </div>

                <button class="btn-add-task"
                        onclick="adicionarEntrega()">

                    ➕ Adicionar Entrega Realizada

                </button>

            </div>

            <div class="delivery-list">

                <div class="review-card-title"
                     style="margin-bottom:18px;">

                    <h2 style="font-size:20px;">
                        📦 Entregas Adicionadas
                    </h2>

                </div>

                <div id="listaEntregasRealizadas"></div>

                <div class="delivery-summary">

                    <div class="delivery-summary-card summary-success">

                        <strong id="totalEntregue">
                            0
                        </strong>

                        <span>
                            Entregues
                        </span>

                    </div>

                    <div class="delivery-summary-card summary-warning">

                        <strong id="totalParcial">
                            0
                        </strong>

                        <span>
                            Parciais
                        </span>

                    </div>

                    <div class="delivery-summary-card summary-danger">

                        <strong id="totalNaoEntregue">
                            0
                        </strong>

                        <span>
                            Não Entregues
                        </span>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="double-grid">

        <div class="review-card">

            <div class="review-card-title">

                <h2>
                    🐞 Bugs e Qualidade
                </h2>

            </div>

            <div class="compact-grid">

                <div class="mini-card">

                    <label>
                        Bugs Críticos
                    </label>

                    <input id="bugsCriticos"
                           placeholder="Digite os bugs críticos">

                </div>

                <div class="mini-card">

                    <label>
                        Bugs Médios
                    </label>

                    <input id="bugsMedios"
                           placeholder="Digite os bugs médios">

                </div>

                <div class="mini-card">

                    <label>
                        Bugs Baixos
                    </label>

                    <input id="bugsBaixos"
                           placeholder="Digite os bugs baixos">

                </div>

                <div class="mini-card">

                    <label>
                        Corrigidos
                    </label>

                    <input id="bugsCorrigidos"
                           placeholder="Digite os bugs corrigidos">

                </div>

                <div class="mini-card">

                    <label>
                        Pendentes
                    </label>

                    <input id="bugsPendentes"
                           placeholder="Digite os bugs pendentes">

                </div>

                <div class="mini-card">

                    <label>
                        Bugs Encontrados
                    </label>

                    <input id="bugsEncontrados"
                           placeholder="Digite os bugs encontrados">

                </div>

            </div>

        </div>

        <div class="review-card">

            <div class="review-card-title">

                <h2>
                    📈 Métricas Avançadas
                </h2>

            </div>

            <div class="compact-grid">

                <div class="mini-card">

                    <label>
                        Story Points Planejados
                    </label>

                    <input id="storyPointsPlanejados"
                           placeholder="Digite os story points">

                </div>

                <div class="mini-card">

                    <label>
                        Story Points Entregues
                    </label>

                    <input id="storyPointsEntregues"
                           placeholder="Digite os story points entregues">

                </div>

                <div class="mini-card">

                    <label>
                        Eficiência da Sprint
                    </label>

                    <input id="eficienciaSprint"
                           placeholder="Digite a eficiência">

                </div>

                <div class="mini-card">

                    <label>
                        Taxa de Sucesso
                    </label>

                    <input id="taxaSucesso"
                           placeholder="Digite a taxa de sucesso">

                </div>

                <div class="mini-card">

                    <label>
                        Tempo Médio de Task
                    </label>

                    <input id="tempoMedioTask"
                           placeholder="Digite o tempo médio">

                </div>

                <div class="mini-card">

                    <label>
                        Participação do Time
                    </label>

                    <input id="participacaoTime"
                           placeholder="Digite a participação">

                </div>

            </div>

        </div>

    </div>

    <div class="review-card feedback-section">

        <div class="feedback-title">

            💬 Conversas e Feedbacks da Sprint

        </div>


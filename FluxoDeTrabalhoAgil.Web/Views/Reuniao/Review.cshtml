    function novaSprint() {

        sprintAtualId = 0;

        document.querySelectorAll("input").forEach(x => {
            x.value = "";
        });

        document.querySelectorAll("textarea").forEach(x => {
            x.value = "";
        });

        document.getElementById(
            "listaEntregasRealizadas"
        ).innerHTML = "";

        entregasSprint = [];

        totalEntregue = 0;
        totalParcial = 0;
        totalNaoEntregue = 0;

        atualizarResumo();

        document.getElementById(
            "cmbSprint"
        ).value = "";

        feedbackAcao(
            "Nova Sprint criada"
        );
    }

    function atualizarResumo() {

        document.getElementById(

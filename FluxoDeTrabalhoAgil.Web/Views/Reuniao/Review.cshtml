<script>
    const API =
            "http://localhost:5228/api/review";

    let totalEntregue = 0;
    let totalParcial = 0;
    let totalNaoEntregue = 0;

    let sprintAtualId = 0;
    let entregasSprint = [];
    window.onload = function () {

        carregarSprints();
    };

    function adicionarEntrega() {

        const nome =
            document.getElementById("nomeEntrega");

        const status =
            document.getElementById("statusEntrega");

        if (!nome.value.trim()) {

            nome.classList.add("task-error");

            nome.focus();

            feedbackAcao(
                "Digite o nome da entrega"
            );

            return;
        }

        nome.classList.remove(
            "task-error"
        );

        entregasSprint.push({
            nome: nome.value,
            status: status.value
        });

        let statusClass = "";

        if (status.value.includes("Não Entregue")) {

            statusClass = "status-no";
            totalNaoEntregue++;
        }
        else if (status.value.includes("Parcial")) {

            statusClass = "status-partial";
            totalParcial++;
        }
        else {

            statusClass = "status-ok";
            totalEntregue++;
        }

        document.getElementById(
            "listaEntregasRealizadas"
        ).innerHTML += `

        <div class="delivery-item">

            <div>

                <strong style="display:block;color:#0f172a;">
                    ${nome.value}
                </strong>

            </div>

            <div style="display:flex;gap:10px;">

                <div class="delivery-status ${statusClass}">
                    ${status.value}
                </div>

                <button
                    class="btn-remove-delivery"
                    onclick="removerEntrega(this,'${status.value}','${nome.value}')">

                    ✕
                </button>

            </div>

        </div>`;

        atualizarResumo();

        nome.value = "";
        status.selectedIndex = 0;
    }

    function removerEntrega(
        botao,
        status,
        nome
    ) {

        entregasSprint =
            entregasSprint.filter(x =>
                !(x.nome === nome &&
                    x.status === status)
            );

        botao.closest(
            '.delivery-item'
        ).remove();

        if (status.includes('Não Entregue'))
            totalNaoEntregue--;

        else if (status.includes('Parcial'))
            totalParcial--;

        else
            totalEntregue--;

        atualizarResumo();
    }

    function feedbackAcao(texto) {

        const antigo =
            document.querySelector(".feedback-toast");

        if (antigo)
            antigo.remove();

        const toast =
            document.createElement("div");

        toast.className =
            "feedback-toast";

        toast.innerHTML = texto;

        document.body.appendChild(toast);

        setTimeout(() => {

            toast.remove();

        }, 2500);
    }

    async function salvarSprint() {

        const campo =
            document.getElementById(
                "nomeSprint"
            );

        if (!campo.value ||
            !campo.value.trim()) {

            campo.classList.add(
                "input-error"
            );

            campo.focus();

            feedbackAcao(
                "Nome da Sprint é obrigatório"
            );

            return;
        }

        campo.classList.remove(
            "input-error"
        );

        const model = {

            id: sprintAtualId,

            nomeSprint:
                campo.value,

            tasksTotais:
                parseInt(
                    document.getElementById("tasksTotais").value || 0
                ),

            tasksConcluidas:
                parseInt(
                    document.getElementById("tasksConcluidas").value || 0
                ),

            tasksNaoConcluidas:
                parseInt(
                    document.getElementById("tasksNaoConcluidas").value || 0
                ),

            velocityEntregue:
                parseInt(
                    document.getElementById("velocityEntregue").value || 0
                ),

            velocityNaoEntregue:
                parseInt(
                    document.getElementById("velocityNaoEntregue").value || 0
                ),

            participantes:
                parseInt(
                    document.getElementById("participantes").value
                ) || 0,

            bugsCriticos:
                parseInt(document.getElementById("bugsCriticos").value || 0),

            bugsMedios:
                parseInt(document.getElementById("bugsMedios").value || 0),

            bugsBaixos:
                parseInt(document.getElementById("bugsBaixos").value || 0),

            bugsCorrigidos:
                parseInt(document.getElementById("bugsCorrigidos").value || 0),

            bugsPendentes:
                parseInt(document.getElementById("bugsPendentes").value || 0),

            bugsEncontrados:
                parseInt(document.getElementById("bugsEncontrados").value || 0),

            storyPointsPlanejados:
                parseInt(document.getElementById("storyPointsPlanejados").value || 0),

            storyPointsEntregues:
                parseInt(document.getElementById("storyPointsEntregues").value || 0),

            eficienciaSprint:
                document.getElementById("eficienciaSprint").value,

            taxaSucesso:
                document.getElementById("taxaSucesso").value,

            tempoMedioTask:
                document.getElementById("tempoMedioTask").value,

            participacaoTime:
                document.getElementById("participacaoTime").value,

            pontosPositivos:
                document.getElementById("pontosPositivos").value,

            pontosMelhoria:
                document.getElementById("pontosMelhoria").value,

            feedbackScrumMaster:
                document.getElementById("feedbackScrumMaster").value,

            feedbackProductOwner:
                document.getElementById("feedbackProductOwner").value,

            proximosPassos:
                document.getElementById("proximosPassos").value,

            decisoesTomadas:
                document.getElementById("decisoesTomadas").value,

            entregas:
                entregasSprint.map(x => ({
                    nome: x.nome,
                    status: x.status
                }))
        };

        let metodo = "POST";

        let url = API;

        if (sprintAtualId > 0) {

            metodo = "PUT";

            url = `${API}/${sprintAtualId}`;
        }

        const response =
            await fetch(url, {

                method: metodo,

                headers: {
                    "Content-Type":
                        "application/json"
                },

                body:
                    JSON.stringify(model)
            });

        const textoResposta = await response.text();

        console.log("STATUS:", response.status);
        console.log("RESPOSTA:", textoResposta);

        if (!response.ok) {

            console.error(textoResposta);

            alert(textoResposta);

            feedbackAcao(
                "Erro ao salvar Sprint"
            );

            return;
        }

        const resultado =
            JSON.parse(textoResposta);

        console.log(resultado);

        sprintAtualId =
            resultado.id;

        const combo =
            document.getElementById(
                "cmbSprint"
            );

        let optionExistente =
            [...combo.options]
                .find(x =>
                    parseInt(x.value) === resultado.id
                );

        if (!optionExistente) {

            const option =
                document.createElement("option");

            option.value =
                resultado.id;

            option.text =
                resultado.nomeSprint;

            combo.appendChild(option);
        }

        await carregarSprints();

        combo.value =
            resultado.id;

        feedbackAcao(
            "Sprint salva com sucesso"
        );
    }

    async function carregarSprints() {

        const response =
            await fetch(API);

        const dados =
            await response.json();

        const combo =
            document.getElementById(
                "cmbSprint"
            );

        combo.innerHTML = `
            <option value="">
                Nova Sprint
            </option>
        `;

        dados.forEach(x => {

            combo.innerHTML += `
                <option value="${x.id}">
                    ${x.nomeSprint}
                </option>
            `;
        });
    }


    function exportarPDF() {

        const { jsPDF } = window.jspdf;

        const doc = new jsPDF(
            "p",
            "mm",
            "a4"
        );

        const valor = v =>
            v && v.toString().trim()
                ? v
                : "-";

        const limparStatus = status => {

            if (!status)
                return "-";

            return status
                .replace("✅", "")
                .replace("⚠", "")
                .replace("❌", "")
                .trim();
        };

        let y = 15;

        doc.setFillColor(15, 23, 42);
        doc.rect(0, 0, 210, 25, "F");

        doc.setTextColor(255, 255, 255);
        doc.setFontSize(22);
        doc.text(
            "SPRINT REVIEW",
            14,
            16
        );

        doc.setFontSize(10);

        doc.text(
            valor(document.getElementById("nomeSprint").value),
            14,
            22
        );

        y = 35;

        function titulo(texto) {

            doc.setFillColor(59, 130, 246);

            doc.rect(
                10,
                y - 5,
                190,
                8,
                "F"
            );

            doc.setTextColor(255);

            doc.setFontSize(12);

            doc.text(
                texto,
                13,
                y
            );

            doc.setTextColor(0);

            y += 12;
        }

        function linha(label, valorCampo) {

            doc.setFontSize(10);

            doc.setFont(undefined, "bold");

            doc.text(
                label + ":",
                12,
                y
            );

            doc.setFont(undefined, "normal");

            doc.text(
                valor(valorCampo).toString(),
                70,
                y
            );

            y += 6;
        }

        titulo("METRICAS");

        linha("Tasks Totais", document.getElementById("tasksTotais").value);
        linha("Tasks Concluidas", document.getElementById("tasksConcluidas").value);
        linha("Tasks Nao Concluidas", document.getElementById("tasksNaoConcluidas").value);
        linha("Velocity Entregue", document.getElementById("velocityEntregue").value);
        linha("Velocity Nao Entregue", document.getElementById("velocityNaoEntregue").value);
        linha("Participantes", document.getElementById("participantes").value);

        y += 4;

        titulo("BUGS E QUALIDADE");

        linha("Bugs Criticos", document.getElementById("bugsCriticos").value);
        linha("Bugs Medios", document.getElementById("bugsMedios").value);
        linha("Bugs Baixos", document.getElementById("bugsBaixos").value);
        linha("Corrigidos", document.getElementById("bugsCorrigidos").value);
        linha("Pendentes", document.getElementById("bugsPendentes").value);
        linha("Encontrados", document.getElementById("bugsEncontrados").value);

        y += 4;

        titulo("METRICAS AVANCADAS");

        linha("Story Points Planejados", document.getElementById("storyPointsPlanejados").value);
        linha("Story Points Entregues", document.getElementById("storyPointsEntregues").value);
        linha("Eficiencia Sprint", document.getElementById("eficienciaSprint").value);
        linha("Taxa Sucesso", document.getElementById("taxaSucesso").value);
        linha("Tempo Medio Task", document.getElementById("tempoMedioTask").value);
        linha("Participacao Time", document.getElementById("participacaoTime").value);

        if (y > 220) {

            doc.addPage();
            y = 20;
        }

        titulo("ENTREGAS");

        if (!entregasSprint.length) {

            linha("Entregas", "-");
        }
        else {

            entregasSprint.forEach((e, i) => {

                doc.setFont(undefined, "bold");

                doc.text(
                    `${i + 1}. ${valor(e.nome)}`,
                    12,
                    y
                );

                doc.setFont(undefined, "normal");

                doc.text(
                    limparStatus(e.status),
                    120,
                    y
                );

                y += 6;
            });
        }

        y += 8;

        titulo("FEEDBACKS");

        linha("Pontos Positivos", document.getElementById("pontosPositivos").value);
        linha("Pontos Melhoria", document.getElementById("pontosMelhoria").value);
        linha("Feedback Scrum Master", document.getElementById("feedbackScrumMaster").value);
        linha("Feedback Product Owner", document.getElementById("feedbackProductOwner").value);
        linha("Proximos Passos", document.getElementById("proximosPassos").value);
        linha("Decisoes Tomadas", document.getElementById("decisoesTomadas").value);

        doc.save(
            `SprintReview_${valor(document.getElementById("nomeSprint").value)}.pdf`
        );
    }


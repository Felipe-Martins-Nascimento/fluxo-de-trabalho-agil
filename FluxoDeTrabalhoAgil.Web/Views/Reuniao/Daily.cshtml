@{
    Layout = "_Layout";
}

<style>
    body {
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        background: radial-gradient(circle at top left, rgba(59,130,246,.18), transparent 22%), radial-gradient(circle at bottom right, rgba(139,92,246,.16), transparent 25%), linear-gradient(135deg, #eef4ff 0%, #f8fbff 45%, #f4f7ff 100%);
        background-attachment: fixed;
        overflow-x: hidden;
        position: relative;
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background: linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
            background-size: 35px 35px;
            pointer-events: none;
            z-index: -1;
        }

    .daily-wrapper {
        max-width: 1400px;
        margin: auto;
        padding: 40px;
        gap: 30px;
    }

    .message-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 30px rgba(0,0,0,.08);
    }

.btn-action:active,
.btn-send:active,
.btn-save-mini:active,
.btn-cancel-mini:active {
    transform: scale(.96);
}

textarea.erro-input {
    border: 2px solid #ef4444 !important;
    animation: shake .3s;
}

.audio-rec {
    display:flex;
    align-items:center;
    gap:12px;
    background:#eff6ff;
    border-radius:18px;
    padding:15px 20px;
    margin-top:15px;
    color:#2563eb;
    font-weight:600;
}

.rec-dot {
    width:12px;
    height:12px;
    border-radius:50%;
    background:red;
    animation:pulse 1s infinite;
}

.calendar-input {
    border:none;
    padding:12px 18px;
    border-radius:14px;
    background:white;
    box-shadow:
        0 5px 20px rgba(0,0,0,.06);
    font-size:14px;
}

.filter-user {
    border:none;
    padding:12px 18px;
    border-radius:14px;
    background:white;
    box-shadow:
        0 5px 20px rgba(0,0,0,.06);
    font-size:14px;
}

.modal-close-x {
    position:absolute;
    top:15px;
    right:15px;
    border:none;
    background:#ef4444;
    color:white;
    width:35px;
    height:35px;
    border-radius:50%;
    cursor:pointer;
    font-size:16px;
}

@@keyframes pulse {

    0% {
        opacity:1;
        transform:scale(1);
    }

    50% {
        opacity:.5;
        transform:scale(1.2);
    }

    100% {
        opacity:1;
        transform:scale(1);
    }
}

@@keyframes shake {

    0% {
        transform:translateX(0);
    }

    25% {
        transform:translateX(-5px);
    }

    50% {
        transform:translateX(5px);
    }

    75% {
        transform:translateX(-5px);
    }

    100% {
        transform:translateX(0);
    }
}

    .daily-wrapper {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .daily-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 34px;
        border-radius: 30px;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(255,255,255,.88), rgba(255,255,255,.72));
        border: 1px solid rgba(255,255,255,.55);
        backdrop-filter: blur(24px);
        box-shadow: 0 20px 50px rgba(37,99,235,.10), 0 10px 30px rgba(0,0,0,.06);
        animation: fadeCard .7s ease;
    }

        .daily-header::before {
            content: "";
            position: absolute;
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(59,130,246,.15), transparent 70%);
            top: -120px;
            right: -100px;
        }

    .daily-title {
        font-size: 42px;
        font-weight: bold;
        color: #0f172a;
    }

    .daily-chat {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 10px 35px rgba(0,0,0,.05);
    }

        .daily-chat::-webkit-scrollbar {
            width: 10px;
        }

        .daily-chat::-webkit-scrollbar-track {
            background: transparent;
        }

        .daily-chat::-webkit-scrollbar-thumb {
            background: linear-gradient( 180deg, #93c5fd, #7c3aed );
            border-radius: 30px;
        }

    .message-card {
        background: #f8fafc;
        border-radius: 22px;
        padding: 25px;
        margin-bottom: 18px;
        animation: slideUpFade .45s ease;
        border: 1px solid #e2e8f0;
    }

    .message-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0;
    }

    .message-user {
        font-weight: bold;
        font-size: 18px;
        color: #0f172a;
    }

    .message-date {
        color: #64748b;
        font-size: 14px;
    }

    .message-content {
        font-size: 15px;
        line-height: 1.7;
        color: #334155;
        margin-top: 0;
        margin-bottom: 2px;
    }

    .message-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .daily-input {
        background: rgba(255,255,255,.78);
        backdrop-filter: blur(18px);
        border-radius: 32px;
        padding: 35px;
        border: 1px solid rgba(255,255,255,.4);
        box-shadow: 0 20px 50px rgba(0,0,0,.06);
    }

    textarea {
        width: 100%;
        height: 180px;
        border: none;
        resize: none;
        border-radius: 20px;
        background: #f8fafc;
        padding: 20px;
        font-size: 16px;
        outline: none;
        box-sizing: border-box;
    }

    .bottom-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 14px;
        margin-top: 22px;
        flex-wrap: wrap;
    }

    .btn-send {
        border: none;
        background: linear-gradient(135deg,#2563eb,#1d4ed8);
        color: white;
        padding: 15px 30px;
        border-radius: 15px;
        font-size: 16px;
        cursor: pointer;
        transition: .3s;
    }

        .btn-send:hover {
            transform: translateY(-2px);
        }

    .summary-box {
        position: relative;
        overflow: hidden;
        background: linear-gradient( 145deg, rgba(255,255,255,.95), rgba(248,251,255,.92) );
        border-radius: 30px;
        padding: 35px;
        border: 1px solid rgba(219,234,254,.9);
        box-shadow: 0 20px 50px rgba(37,99,235,.08), 0 10px 25px rgba(0,0,0,.05);
        color: #0f172a;
    }

        .summary-box::before {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(124,58,237,.12), transparent 70%);
            top: -120px;
            right: -80px;
        }

    .reply-box {
        margin-top: 1px;
        background: white;
        border-radius: 15px;
        padding: 12px 15px;
    }

    .loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 50px;
        font-size: 18px;
        color: #64748b;
    }

    @@keyframes fade {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    #toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #0f172a;
        color: white;
        padding: 15px 25px;
        border-radius: 15px;
        opacity: 0;
        transition: .4s;
        z-index: 999;
    }


    .btn-save-mini {
        border: none;
        background: #2563eb;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        font-size: 13px;
        cursor: pointer;
    }

    .btn-cancel-mini {
        border: none;
        background: #e2e8f0;
        color: #0f172a;
        padding: 8px 18px;
        border-radius: 10px;
        font-size: 13px;
        cursor: pointer;
    }

    .audio-item {
        background: white;
        padding: 15px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,.06);
    }

        .audio-item audio {
            width: 90%;
        }

    .btn-delete-audio {
        border: none;
        background: #ef4444;
        color: white;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        cursor: pointer;
    }

    .select-area {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .label-select {
        font-size: 15px;
        color: #475569;
        font-weight: 600;
    }

    .input-label {
        display: block;
        margin-bottom: 12px;
        font-weight: 600;
        color: #0f172a;
        font-size: 16px;
    }

    .modal-confirm {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 99999;
    }

    .modal-confirm-content {
        background: white;
        width: 400px;
        border-radius: 25px;
        padding: 30px;
        animation: fade .3s;
    }

    .modal-confirm-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 25px;
    }

    .audio-preview-card {
        background: #fff;
        border-radius: 18px;
        padding: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 15px;
    }

        .audio-preview-card audio {
            width: 100%;
        }

    .audio-message {
        margin-top: 15px;
        background: white;
        border-radius: 18px;
        padding: 12px;
    }

        .audio-message audio {
            width: 100%;
        }

    #btnGravar:disabled {
        background: #cbd5e1 !important;
        color: #475569 !important;
        cursor: not-allowed;
    }

        #btnGravar:disabled:hover {
            background: #cbd5e1 !important;
            color: #475569 !important;
            transform: none !important;
        }

    #btnParar {
        background: #ef4444;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 120px;
    }

        #btnParar:hover {
            background: #dc2626 !important;
            color: white !important;
        }

    .audio-list-message {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 6px;
    }

    .audio-message-card {
        background: linear-gradient( 135deg, rgba(255,255,255,.96), rgba(239,246,255,.98) );
        border-radius: 20px;
        padding: 16px;
        border: 1px solid #dbeafe;
        box-shadow: 0 6px 20px rgba(37,99,235,.10);
        transition: .25s;
    }

        .audio-message-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 35px rgba(37,99,235,.14);
        }

    .audio-top {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 15px;
    }

    .audio-icon {
        width: 50px;
        height: 50px;
        border-radius: 18px;
        background: linear-gradient( 135deg, #2563eb, #1d4ed8 );
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 22px;
        box-shadow: 0 10px 25px rgba(37,99,235,.25);
    }

    .audio-icon {
        animation: pulseAudio 2s infinite;
    }

    @@keyframes pulseAudio {

        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
        }
    }

    .audio-info {
        display: flex;
        flex-direction: column;
    }

        .audio-info strong {
            color: #0f172a;
            font-size: 15px;
        }

        .audio-info span {
            color: #64748b;
            font-size: 13px;
        }

    .audio-player {
        width: 100%;
        border-radius: 14px;
    }

    .daily-title {
        font-size: 42px;
        font-weight: 900;
        letter-spacing: -2px;
        background: linear-gradient( 135deg, #2563eb, #7c3aed, #0f172a );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        position: relative;
    }

        .daily-title::after {
            content: "⚡";
            position: absolute;
            top: -6px;
            right: -32px;
            font-size: 22px;
            animation: pulseIcon 2s infinite;
        }

    .daily-chat {
        background: linear-gradient( 180deg, rgba(255,255,255,.92), rgba(248,251,255,.90) );
        border: 1px solid rgba(255,255,255,.55);
        border-radius: 30px;
        backdrop-filter: blur(22px);
        box-shadow: 0 25px 60px rgba(37,99,235,.08), 0 10px 25px rgba(0,0,0,.05);
        position: relative;
        padding: 25px;
        max-height: 950px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .message-card {
        position: relative;
        background: linear-gradient( 145deg, rgba(255,255,255,.96), rgba(248,251,255,.95) );
        border: 1px solid rgba(219,234,254,.85);
        border-radius: 28px;
        padding: 18px;
        overflow: hidden;
        box-shadow: 0 10px 35px rgba(37,99,235,.08), 0 5px 18px rgba(0,0,0,.04);
        transition: transform .28s ease, box-shadow .28s ease, border .28s ease;
        animation: slideUpFade .5s ease;
    }

        .message-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient( 135deg, rgba(59,130,246,.04), transparent 45%, rgba(124,58,237,.05) );
            pointer-events: none;
        }

        .message-card:hover {
            transform: translateY(-6px) scale(1.01);
            border-color: rgba(147,197,253,.95);
            box-shadow: 0 25px 45px rgba(37,99,235,.15), 0 10px 25px rgba(0,0,0,.05);
        }

    .btn-action {
        position: relative;
        overflow: hidden;
        background: linear-gradient( 135deg, rgba(255,255,255,.92), rgba(239,246,255,.92) );
        border: 1px solid rgba(191,219,254,.9);
        border-radius: 16px;
        padding: 12px 20px;
        font-weight: 700;
        color: #1e293b;
        cursor: pointer;
        transition: all .28s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 0 8px 20px rgba(37,99,235,.08);
    }

        .btn-action::before {
            content: "";
            position: absolute;
            top: 0;
            left: -120%;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,.45);
            transform: skewX(-25deg);
            transition: .6s;
        }

        .btn-action:hover::before {
            left: 120%;
        }

        .btn-action:hover {
            transform: translateY(-3px);
            background: linear-gradient( 135deg, #eff6ff, #dbeafe );
            border-color: #93c5fd;
            color: #2563eb;
            box-shadow: 0 15px 30px rgba(37,99,235,.18);
        }

    .btn-send {
        position: relative;
        overflow: hidden;
        font-weight: bold;
        letter-spacing: .3px;
        box-shadow: 0 10px 30px rgba(37,99,235,.30);
    }

        .btn-send:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 15px 40px rgba(37,99,235,.40);
        }

        .btn-send::before {
            content: "";
            position: absolute;
            top: 0;
            left: -120%;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,.2);
            transform: skewX(-25deg);
            transition: .6s;
        }

        .btn-send:hover::before {
            left: 120%;
        }

    .btn-limpar-filtro {
        border: none;
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
        padding: 12px 22px;
        border-radius: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: .28s;
        box-shadow: 0 10px 25px rgba(239,68,68,.25);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-limpar-filtro:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 35px rgba(239,68,68,.35);
            filter: brightness(1.05);
        }
    .summary-box {
        position: relative;
        overflow: hidden;
    }

    textarea {
        transition: .3s;
        border: 2px solid transparent;
    }

        textarea:focus {
            border: 2px solid #93c5fd;
            box-shadow: 0 0 0 6px rgba(147,197,253,.20), 0 15px 35px rgba(37,99,235,.10);
            transform: translateY(-2px);
        }

    .modal-confirm-content,
    #modalContent {
        box-shadow: 0 30px 80px rgba(0,0,0,.25);
        animation: fade .25s ease;
    }

    .reply-box {
        background: linear-gradient( 135deg, #ffffff, #f8fbff );
        border: 1px solid #dbeafe;
        padding: 18px;
    }

    #toast {
        backdrop-filter: blur(10px);
        background: rgba(15,23,42,.92);
        box-shadow: 0 15px 40px rgba(0,0,0,.25);
    }

    .audio-preview-card {
        border: 1px solid #dbeafe;
        transition: .3s;
    }

        .audio-preview-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(37,99,235,.12);
        }

    .filter-user,
    .calendar-input,
    #filtroData {
        transition: .3s;
    }

        .filter-user:focus,
        .calendar-input:focus,
        #filtroData:focus {
            outline: none;
            box-shadow: 0 0 0 5px rgba(37,99,235,.15);
        }

    .btn-send {
        border: none;
        background: #2563eb;
        color: white;
        padding: 16px 32px;
        border-radius: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s;
        box-shadow: 0 8px 20px rgba(37,99,235,.25);
    }

        .btn-send:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
        }

    textarea {
        width: 100%;
        min-height: 180px;
        border-radius: 22px;
        background: rgba(255,255,255,.95);
        border: 1px solid #dbeafe;
        padding: 24px;
        font-size: 16px;
        outline: none;
        resize: vertical;
        transition: .28s;
        line-height: 1.7;
    }

        textarea:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(37,99,235,.12);
        }

    @@keyframes slideUpFade {

        from {
            opacity: 0;
            transform: translateY(40px) scale(.96);
            filter: blur(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
            filter: blur(0);
        }
    }

    .btn-action:hover,
    .btn-send:hover {
        filter: brightness(1.05);
    }

    @@keyframes fadeCard {

        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes pulseIcon {

        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.15);
        }

        100% {
            transform: scale(1);
        }
    }

    .daily-input {
        position: relative;
        overflow: hidden;
        background: linear-gradient( 145deg, rgba(255,255,255,.94), rgba(248,251,255,.92) );
        border: 1px solid rgba(219,234,254,.9);
        box-shadow: 0 20px 55px rgba(37,99,235,.10), 0 10px 25px rgba(0,0,0,.05);
    }

        .daily-input::before {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            background: radial-gradient(circle, rgba(37,99,235,.10), transparent 70%);
            top: -120px;
            right: -100px;
        }

    .select-area {
        background: rgba(255,255,255,.65);
        padding: 12px 18px;
        border-radius: 20px;
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255,255,255,.45);
    }

    .filter-user,
    .calendar-input,
    #filtroData {
        background: linear-gradient( 135deg, #ffffff, #eff6ff );
        border: 1px solid #dbeafe;
        color: #1e293b;
        font-weight: 600;
    }

        .filter-user:hover,
        .calendar-input:hover,
        #filtroData:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(37,99,235,.12);
        }

    .reply-box {
        border-radius: 20px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.8), 0 8px 20px rgba(37,99,235,.08);
    }

    .modal-confirm-content,
    #modalContent {
        background: linear-gradient( 145deg, rgba(255,255,255,.97), rgba(248,251,255,.95) );
        border: 1px solid rgba(219,234,254,.8);
    }

    .audio-message-card {
        position: relative;
        overflow: hidden;
    }

        .audio-message-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient( 135deg, rgba(59,130,246,.04), transparent 45%, rgba(124,58,237,.05) );
            pointer-events: none;
        }

    .message-content {
        max-height: 120px;
        overflow-y: auto;
        padding-right: 10px;
    }

        .message-content::-webkit-scrollbar {
            width: 8px;
        }

        .message-content::-webkit-scrollbar-track {
            background: transparent;
        }

        .message-content::-webkit-scrollbar-thumb {
            background: linear-gradient( 180deg, #93c5fd, #7c3aed );
            border-radius: 20px;
        }

    .replies-wrapper {
        margin-top: 2px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        max-height: 260px;
        overflow-y: auto;
        padding-right: 6px;
    }

        .replies-wrapper::-webkit-scrollbar {
            width: 8px;
        }

        .replies-wrapper::-webkit-scrollbar-thumb {
            background: linear-gradient( 180deg, #60a5fa, #8b5cf6 );
            border-radius: 20px;
        }

    .reply-box {
        position: relative;
        background: linear-gradient(135deg, rgba(255,255,255,.95), rgba(239,246,255,.92));
        border: 1px solid #dbeafe;
        border-radius: 20px;
        padding: 8px 16px;
        animation: fadeReply .35s ease;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .reply-box::before {
            content: "";
            position: absolute;
            left: 0;
            top: 18px;
            width: 4px;
            height: calc(100% - 36px);

<script>

    const usuarioLogado = "Felipe Martins";

    const API = "http://localhost:5228/api/daily";

    let mediaRecorder;
    let idRespostaAtual = 0;
    let audioChunks = [];

    let audiosTemporarios = [];
    let primeiraCarga = true;

    function formatarDataISO(data) {

    const d = new Date(data);

    const ano = d.getFullYear();

    const mes =
        String(d.getMonth() + 1)
            .padStart(2, "0");

    const dia =
        String(d.getDate())
            .padStart(2, "0");

    return `${ano}-${mes}-${dia}`;
}

    async function carregarMensagens() {

        const area =
            document.getElementById("messages");

        area.innerHTML = `
            <div class="loading">
                <div class="rec-dot"></div>
                Carregando mensagens...
            </div>
        `;

        try {

            const response = await fetch(API);

            if (!response.ok)
                throw new Error();

            const dados = await response.json();

            popularDatas(dados);

            let mensagensFiltradas = dados;

            const usuarioFiltro =
                document.getElementById("filtroUsuario").value;

            const filtro =
                document.getElementById("filtroData").value;

            if (primeiraCarga) {

                const hoje = formatarDataISO(new Date());

                mensagensFiltradas =
                    dados.filter(x =>
                        formatarDataISO(x.data) === hoje
                    );

                document.getElementById("filtroData").value = hoje;

                primeiraCarga = false;
            }
            else {

                if (filtro !== "") {

                    mensagensFiltradas =
                        mensagensFiltradas.filter(x =>
                            formatarDataISO(x.data) === filtro
                        );
                }
            }

            if (usuarioFiltro !== "") {

                mensagensFiltradas =
                    mensagensFiltradas.filter(x =>
                        x.usuario === usuarioFiltro
                    );
            }

            area.innerHTML = "";

            if (mensagensFiltradas.length === 0) {

                area.innerHTML = `
                    <div class="loading">
                        🗒️ Não há nenhuma Daily registrada hoje.
                    </div>
                `;

                return;
            }

            mensagensFiltradas.forEach(m => {
                renderizarMensagem(m);
            });

        }
        catch (erro) {

            console.error(erro);

            area.innerHTML = `
                <div class="loading">
                    API offline ou erro na conexão.
                </div>
            `;
        }
    }

    function formatarDataBR(data) {

        const partes = data.split("-");

        return `${partes[2]}/${partes[1]}/${partes[0]}`;
    }

    function popularDatas(dados) {

        const select =
            document.getElementById("filtroData");

        const valorAtual =
            select.value;

        const datas =
            [...new Set(

                dados.map(x =>

                    formatarDataISO(x.data)

                )

            )];

        select.innerHTML =
            `<option value="">Todas</option>`;

        datas.forEach(data => {

            select.innerHTML += `

                <option value="${data}">
                    ${formatarDataBR(data)}
                </option>

            `;
        });

        if (!valorAtual) {

            const hoje =
                formatarDataISO(new Date());

            select.value = hoje;
        }

        select.value = valorAtual;

        popularUsuarios(dados);
    }

    function popularUsuarios(dados) {

        const select =
            document.getElementById(
                "filtroUsuario"
            );

        const atual =
            select.value;

        const usuarios =
            [...new Set(
                dados.map(x => x.usuario)
            )];

        select.innerHTML = `

            <option value="">
                Todas Pessoas
            </option>

        `;

        usuarios.forEach(usuario => {

            select.innerHTML += `

                <option value="${usuario}">
                    ${usuario}
                </option>

            `;
        });

        select.value = atual;
    }

    async function enviarMensagem() {

        const input =
            document.getElementById("messageInput");

        const texto =
            input.value.trim();

        if (!texto && audiosTemporarios.length === 0) {

            input.classList.add("erro-input");

            input.placeholder =
                "Digite uma mensagem ou grave um áudio para continuar...";

            input.focus();

            mostrarToast(
                "Preencha a Daily antes de enviar."
            );

            setTimeout(() => {

                input.classList.remove("erro-input");

            }, 1200);

            return;
        }

        try {

            const body = {

                usuario: usuarioLogado,

                texto: texto,

                audios:
                    audiosTemporarios
            };

            const response =
                await fetch(API, {

                    method: "POST",

                    headers: {
                        "Content-Type":
                            "application/json"
                    },

                    body: JSON.stringify(body)
                });

            if (!response.ok)
                throw new Error();

            input.value = "";

            audiosTemporarios = [];

            document.getElementById(
                "audioPreview"
            ).innerHTML = "";

            mostrarToast(
                "Daily enviada."
            );

            carregarMensagens();

        }
        catch {

            mostrarToast(
                "Erro ao enviar."
            );
        }
    }

    function renderizarMensagem(mensagem) {

        const area =
            document.getElementById("messages");

        const div =
            document.createElement("div");

        div.className =
            "message-card";

        div.innerHTML = `

            <div class="message-header">

                <div>

                    <div class="message-user">
                        ${mensagem.usuario}
                    </div>

                    <div class="message-date">
                        ${new Date(mensagem.data)
                .toLocaleString()}
                    </div>

                </div>

            </div>

            <div class="message-content"
                 id="texto-${mensagem.id}"
                 style="white-space:pre-line;">
                ${mensagem.texto || ""}
            </div>

                        ${mensagem.audios &&
                mensagem.audios.length > 0 ?

                `

    <div class="audio-list-message">

        ${mensagem.audios.map((audio, index) => `

            <div class="audio-message-card">

                <div class="audio-top">

                    <div class="audio-icon">
                        🎧
                    </div>

                    <div class="audio-info">

                        <strong>
                            Áudio ${index + 1}
                        </strong>

                        <span>
                            Daily em áudio
                        </span>

                    </div>

                </div>

                <audio controls
                       class="audio-player"
                       src="${audio}">
                </audio>

            </div>

        `).join("")}

    </div>

    ` : ""}

            <div class="message-actions">

                ${mensagem.usuario === usuarioLogado ?

                `

                <button class="btn-action"
                        onclick="habilitarEdicao(${mensagem.id})">
                    ✏ Editar
                </button>

                <button class="btn-action"
                        onclick="abrirExcluir(${mensagem.id})">
                    🗑 Excluir
                </button>

                ` : ""}

                <button class="btn-action"
                        onclick="copiarMensagem(\`${mensagem.texto}\`)">
                    📋 Copiar
                </button>

                <button class="btn-action"
                        onclick="abrirNota(${mensagem.id})">
                    ⭐ ${mensagem.nota}
                </button>

                <button class="btn-action"
                        onclick="responderMensagem(${mensagem.id})">
                    💬 Responder
                </button>

                    ${mensagem.texto && mensagem.texto.trim() !== "" ?

                `

                    <button class="btn-action"
                            onclick="gerarResumoMensagem(${mensagem.id})">
                        🤖 IA
                    </button>

                ` : ""}

            </div>

                           <div id="resposta-${mensagem.id}">

        ${(mensagem.respostas || []).length > 0
                ? `
        <div class="replies-wrapper">

                    ${(mensagem.respostas || []).map(r => `

        <div class="reply-box">

                <div class="reply-user">
                💬 ${r.usuario || r.Usuario}
            </div><div class="reply-text">
                ${r.texto || r.Texto}
            </div><div class="reply-date">
                ${new Date(r.data || r.Data).toLocaleString()}
            </div>

                </div>

            `).join("")}

                </div>
                `
                        : ""
                    }

        </div>

        `;

        area.appendChild(div);
    }

    function habilitarEdicao(id) {

        const textoDiv =
            document.getElementById(`texto-${id}`);

        const textoAtual =
            textoDiv.innerText;

        const actions =
            textoDiv.parentElement.querySelector(".message-actions");

        actions.innerHTML = `

            <button class="btn-action"
                    onclick="salvarEdicao(${id})">
                ✔ Salvar
            </button>

            <button class="btn-action"
                    onclick="carregarMensagens()">
                ✖ Cancelar
            </button>

        `;

        textoDiv.innerHTML = `

            <textarea id="edit-${id}"
                      style="
                        width:100%;
                        min-height:140px;
                        border:none;
                        border-radius:18px;
                        padding:20px;
                        background:#fff;
                        white-space:pre-line;
                        font-size:15px;
                      ">${textoAtual}</textarea>

        `;
    }

    async function salvarEdicao(id) {

        const texto =
            document.getElementById(`edit-${id}`)
                .value;

        await fetch(`${API}/${id}`, {

            method: "PUT",

            headers: {
                "Content-Type":
                    "application/json"
            },

            body: JSON.stringify(texto)
        });

        mostrarToast(
            "Mensagem atualizada."
        );

        carregarMensagens();
    }

    function copiarMensagem(texto) {

        navigator.clipboard.writeText(texto);

        mostrarToast(
            "Mensagem copiada."
        );
    }

    function mostrarToast(texto) {

        const toast =
            document.getElementById("toast");

        toast.innerText = texto;

        toast.style.opacity = "1";

        setTimeout(() => {

            toast.style.opacity = "0";

        }, 2500);
    }

    function responderMensagem(id) {

        idRespostaAtual = id;

        document.getElementById(
            "modalResposta"
        ).style.display = "flex";

        document.getElementById(
            "textoResposta"
        ).value = "";
    }

    function abrirNota(id) {

        const modal =
            document.getElementById("notaModal");

        modal.style.display = "flex";

        window.idNotaAtual = id;
    }

    async function selecionarNota(nota) {

        await fetch(
            `${API}/${window.idNotaAtual}/nota`,
            {

                method: "PUT",

                headers: {
                    "Content-Type":
                        "application/json"
                },

                body: JSON.stringify(nota)
            });

        fecharNota();

        mostrarToast(
            "Nota enviada."
        );
        const scrollAtual = window.scrollY;
        carregarMensagens();
        setTimeout(() => {

            window.scrollTo({
                top: scrollAtual,
                behavior: "instant"
            });

        }, 50);
    }

    function fecharNota() {

        document.getElementById("notaModal")
            .style.display = "none";
    }

    async function gerarResumoMensagem(id) {
        document.querySelector(".summary-box")
            .scrollIntoView({
                behavior: "smooth",
                block: "center"
            });
        const div =
            document.getElementById("iaSummary");

        div.innerHTML = `

        <div style="
            display:flex;
            align-items:center;
            gap:12px;
            font-size:18px;
        ">

            <div class="rec-dot"></div>

            IA analisando Daily...

        </div>

    `;

        try {

            const elementoTexto =
                document.getElementById(
                    `texto-${id}`
                );

            let texto =
                elementoTexto.innerText;

            texto =
                texto
                    .replace(/Áudio\s\d+/gi, "")
                    .replace(/Daily em áudio/gi, "")
                    .trim();

            const response =
                await fetch(`${API}/resumo`, {

                    cache: "no-cache",

                    method: "POST",

                    headers: {
                        "Content-Type":
                            "application/json"
                    },

                    body: JSON.stringify(texto)
                });

            const resumo =
                await response.text();

            div.innerHTML = `

                    <div style="
                        line-height:1.9;
                        white-space:pre-line;
                    ">
                        ${resumo}
                    </div>

                `;
        }
        catch (erro) {

            console.error(erro);

            div.innerHTML = `

            <div style="
                color:#fecaca;
                line-height:1.8;
            ">

                ❌ Erro ao gerar resumo IA.

                <br><br>

                Verifique se o Ollama está aberto com:

                <br><br>

                ollama run llama3

            </div>

        `;
        }
    }

    async function iniciarGravacao() {

        try {

            const stream =
                await navigator.mediaDevices
                    .getUserMedia({
                        audio: true
                    });

            mediaRecorder =
                new MediaRecorder(stream);

            audioChunks = [];

            mediaRecorder.start();

            const btnGravar =
                document.getElementById(
                    "btnGravar"
                );

            btnGravar.disabled = true;

            btnGravar.innerHTML =
                "🎙 Áudio sendo gravado";

            document.getElementById(
                "btnParar"
            ).style.display = "inline-flex";

            document.getElementById(
                "statusAudio"
            ).innerHTML = `

                <div class="audio-rec">

                    <div class="rec-dot"></div>

                    Gravando áudio da Daily...

                </div>

            `;

            mediaRecorder.ondataavailable =
                e => {

                    audioChunks.push(e.data);
                };

        }
        catch {

            mostrarToast(
                "Permita acesso ao microfone."
            );
        }
    }

    function pararGravacao() {

        if (!mediaRecorder)
            return;

        mediaRecorder.stop();

        document.getElementById(
            "btnParar"
        ).style.display = "none";

        mediaRecorder.onstop = () => {

            const blob =
                new Blob(audioChunks, {
                    type: "audio/webm"
                });

            const reader = new FileReader();

            reader.onloadend = () => {

                const base64 =
                    reader.result;

                audiosTemporarios.push(base64);

                renderizarPreviewAudio(base64);
            };

            reader.readAsDataURL(blob);

            document.getElementById(
                "statusAudio"
            ).innerHTML = "";

            const btnGravar =
                document.getElementById(
                    "btnGravar"
                );

            btnGravar.disabled = false;

            btnGravar.innerHTML =
                "🎤 Gravar Áudio";

        };
    }

    function renderizarAudio(url) {

        const area =
            document.getElementById("statusAudio");

        const div =
            document.createElement("div");

        div.className =
            "audio-item";

        div.innerHTML = `

                <audio controls
                       src="${url}">
                </audio>

                <button class="btn-delete-audio"
                        onclick="removerAudio(this, '${url}')">
                    ✖
                </button>

            `;

        area.appendChild(div);
    }

    function removerAudio(botao, url) {

        audiosTemporarios =
            audiosTemporarios.filter(
                x => x !== url
            );

        botao.parentElement.remove();

        mostrarToast(
            "Áudio removido."
        );
    }

    carregarMensagens();


    function filtrarDataManual(data) {

        if (!data)
            return;

        document.getElementById(
            "filtroData"
        ).value = data;

        carregarMensagens();
    }

    function selecionarFiltroCombo() {

        const combo =
            document.getElementById("filtroData");

        const calendario =
            document.getElementById("calendarFiltro");

        if (combo.value !== "") {

            calendario.disabled = true;

            calendario.style.opacity = ".5";
            calendario.style.cursor = "not-allowed";
        }
        else {

            calendario.disabled = false;

            calendario.style.opacity = "1";
            calendario.style.cursor = "pointer";
        }

        carregarMensagens();
    }

    function filtrarDataManual(data) {

        const combo =
            document.getElementById("filtroData");

        if (!data)
            return;

        combo.disabled = true;

        combo.style.opacity = ".5";
        combo.style.cursor = "not-allowed";

        combo.value = data;

        carregarMensagens();
    }

    window.onclick = function (event) {

        const modal =
            document.getElementById(
                "notaModal"
            );

        if (event.target === modal) {

            fecharNota();
        }
    };

    let idExcluir = 0;

    function abrirExcluir(id) {

        idExcluir = id;

        document.getElementById(
            "modalExcluir"
        ).style.display = "flex";
    }

    function fecharModalExcluir() {

        document.getElementById(
            "modalExcluir"
        ).style.display = "none";
    }

    async function confirmarExcluir() {

        try {

            const response =
                await fetch(`${API}/${idExcluir}`, {

                    method: "DELETE"
                });

            if (!response.ok)
                throw new Error();

            fecharModalExcluir();

            mostrarToast(
                "Daily excluída."
            );

            const scrollAtual = window.scrollY;
            carregarMensagens();
            setTimeout(() => {

                window.scrollTo({
                    top: scrollAtual,
                    behavior: "instant"
                });

            }, 50);
        }
        catch {

            mostrarToast(
                "Erro ao excluir."
            );
        }
    }

    function renderizarPreviewAudio(url) {

        const area =
            document.getElementById(
                "audioPreview"
            );

        const div =
            document.createElement("div");

        div.className =
            "audio-preview-card";

        div.innerHTML = `

            <audio controls
                   src="${url}">
            </audio>

            <button class="btn-delete-audio"
                    onclick="removerAudioPreview(this, '${url}')">
                ✖
            </button>

        `;

        area.appendChild(div);
    }

    function removerAudioPreview(botao, url) {

        audiosTemporarios =
            audiosTemporarios.filter(
                x => x !== url
            );

        botao.parentElement.remove();

        mostrarToast(
            "Áudio removido."
        );
    }

    window.addEventListener("click", function (e) {

        const modalExcluir =
            document.getElementById(
                "modalExcluir"
            );

        if (e.target === modalExcluir) {

            fecharModalExcluir();
        }
    });

    function fecharModalResposta() {

        document.getElementById(
            "modalResposta"
        ).style.display = "none";

        document.getElementById(
            "textoResposta"
        ).value = "";
    }

    async function enviarRespostaModal() {

        const resposta =
            document.getElementById(
                "textoResposta"
            ).value.trim();

        if (!resposta) {

            mostrarToast(
                "Digite uma resposta."
            );

            return;
        }

        await fetch(`${API}/${idRespostaAtual}/resposta`, {

            method: "PUT",

            headers: {
                "Content-Type":
                    "application/json"
            },

            body: JSON.stringify({

                texto: resposta,

                usuario: usuarioLogado
            })
        });

        fecharModalResposta();

        mostrarToast(
            "Resposta enviada."
        );

        const scrollAtual = window.scrollY;
        carregarMensagens();
        setTimeout(() => {

            window.scrollTo({
                top: scrollAtual,
                behavior: "instant"
            });

        }, 50);
    }

    window.addEventListener("click", function (e) {

        const modalExcluir =
            document.getElementById(
                "modalExcluir"
            );

        const modalResposta =
            document.getElementById(
                "modalResposta"
            );

        const modalNota =
            document.getElementById(
                "notaModal"
            );

        if (e.target === modalExcluir) {

            fecharModalExcluir();
        }

        if (e.target === modalResposta) {

            fecharModalResposta();

            document.getElementById(
                "textoResposta"
            ).value = "";
        }

        if (e.target === modalNota) {

            fecharNota();
        }
    });

    function limparFiltrosData() {

        const combo =
            document.getElementById("filtroData");

        const calendario =
            document.getElementById("calendarFiltro");

        const usuario =
            document.getElementById("filtroUsuario");

        combo.disabled = false;
        calendario.disabled = false;

        combo.style.opacity = "1";
        calendario.style.opacity = "1";

        combo.style.cursor = "pointer";
        calendario.style.cursor = "pointer";

        combo.value = "";
        calendario.value = "";
        usuario.value = "";

        carregarMensagens();

        mostrarToast(
            "Filtros limpos."
        );
    }
</script>
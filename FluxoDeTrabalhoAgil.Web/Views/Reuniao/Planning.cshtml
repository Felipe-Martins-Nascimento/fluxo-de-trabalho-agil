    }

    .actions-left {
        display: flex;
        align-items: flex-end;
    }

    .actions-right {
        display: flex;
        align-items: flex-end;
        gap: 12px;
    }

    .sprint-select select {
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 14px;
        min-width: 220px;
        max-width: 260px;
    }

    .planning-header {
        display: flex;
        flex-direction: column;
        gap: 10px;
    } 

    .header-top {
        display: flex;
        flex-direction: column;
        gap: 2px; 
        margin-bottom: 4px;
    }

    .top-actions {
        display: flex;
        justify-content: space-between;
        align-items: center; 
        flex-wrap: nowrap; 
        gap: 18px;
        padding-top: 4px; 
        border-top: 1px solid rgba(226,232,240,.7);
    }

    .actions-left {
        flex: 1;
        display: flex;
        align-items: center;
    }

    .actions-right {
        display: flex;
        align-items: center; 
        gap: 12px;
        flex-shrink: 0;

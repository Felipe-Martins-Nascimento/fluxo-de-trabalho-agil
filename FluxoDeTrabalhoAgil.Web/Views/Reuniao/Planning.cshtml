@{
    Layout = "_Layout";
}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx-js-style/dist/xlsx.bundle.js"></script>

<style>
    body {
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        background: radial-gradient(circle at top left, rgba(59,130,246,.18), transparent 22%), radial-gradient(circle at bottom right, rgba(139,92,246,.16), transparent 25%), linear-gradient(135deg,#eef4ff 0%,#f8fbff 45%,#f4f7ff 100%);
        background-attachment: fixed;
    }

    .planning-wrapper {
        max-width: 1800px;
        margin: auto;
        padding: 35px;
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .planning-header {
        background: rgba(255,255,255,.82);
        backdrop-filter: blur(25px);
        border-radius: 35px;
        padding: 35px;
        border: 1px solid rgba(255,255,255,.5);
        box-shadow: 0 20px 50px rgba(37,99,235,.10);
    }

    .planning-title {
        font-size: 48px;
        font-weight: 900;
        letter-spacing: -2px;
        background: linear-gradient(135deg, #2563eb, #7c3aed, #0f172a);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        position: relative;
    }

        .planning-title::after {
            content: "🚀";
            position: absolute;
            top: -6px;
            right: -40px;
            font-size: 22px;
            animation: pulseIcon 2s infinite;
        }

    .planning-subtitle {
        color: #475569;
        font-size: 16px;
    }

    .top-actions {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        margin-top: 30px;
    }

    .glass-card {
        background: rgba(255,255,255,.82);
        backdrop-filter: blur(25px);
        border-radius: 30px;
        padding: 28px;
        border: 1px solid rgba(255,255,255,.5);
        box-shadow: 0 20px 50px rgba(37,99,235,.08);
    }

    .section-title {
        font-size: 25px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 20px;
    }

    .grid-2 {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(400px,1fr));
        gap: 25px;
    }

    .grid-3 {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
        gap: 25px;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 20px;
    }

    .input-label {
        font-size: 14px;
        font-weight: 700;
        color: #334155;
    }

    .input,
    textarea,
    select {
        width: 100%;
        border: none;
        background: #f8fafc;
        border-radius: 18px;
        padding: 16px;
        font-size: 15px;
        outline: none;
        border: 1px solid #dbeafe;
        transition: .25s;
    }

    textarea {
        resize: vertical;
        min-height: 140px;
    }

        .input:focus,
        textarea:focus,
        select:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 5px rgba(37,99,235,.12);
        }

    .btn-primary {
        border: none;
        background: linear-gradient(135deg,#2563eb,#1d4ed8);
        color: white;
        padding: 15px 25px;
        border-radius: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s;
    }

        .btn-primary:hover {
            transform: translateY(-3px);
        }

    .btn-danger {
        border: none;
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
        padding: 15px 25px;
        border-radius: 16px;
        font-weight: 700;
        cursor: pointer;
    }

    .btn-secondary {
        border: none;
        background: #e2e8f0;
        color: #0f172a;
        padding: 15px 25px;
        border-radius: 16px;
        font-weight: 700;
        cursor: pointer;
    }

    .metric-card {
        background: linear-gradient(135deg,#ffffff,#eff6ff);
        border-radius: 24px;
        padding: 25px;
        border: 1px solid #dbeafe;
    }

    .metric-title {
        font-size: 14px;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 8px;
    }

    .metric-number {
        font-size: 42px;
        font-weight: 900;
        color: #2563eb;
    }

    .metric-sub {
        margin-top: 10px;
        color: #475569;
        line-height: 1.6;
    }

    .health-box {
        background: linear-gradient(135deg,#fff,#f8fbff);
        border: 1px solid #dbeafe;
        border-radius: 25px;
        padding: 25px;
    }

    .health-range {
        width: 100%;
    }

    .health-status {
        margin-top: 18px;
        font-size: 18px;
        font-weight: 800;
    }

    .health-progress {
        width: 100%;
        height: 18px;
        border-radius: 30px;
        background: #e2e8f0;
        overflow: hidden;
        margin-top: 18px;
    }

    .health-progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(135deg,#22c55e,#16a34a);
        transition: .4s;
    }

    .backlog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(380px,1fr));
        gap: 25px;
    }

    .task-column {
        background: linear-gradient(135deg,#fff,#f8fbff);
        border-radius: 28px;
        padding: 25px;
        border: 1px solid #dbeafe;
        height: 520px;
        overflow-y: auto;
    }

        .task-column::-webkit-scrollbar {
            width: 10px;
        }

        .task-column::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 20px;
        }

        .task-column::-webkit-scrollbar-track {
            background: transparent;
        }

        .task-column h3 {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 20px;
        }

    .task-card {
        background: white;
        border-radius: 22px;
        padding: 20px;
        margin-bottom: 18px;
        border: 1px solid #dbeafe;
        box-shadow: 0 10px 25px rgba(37,99,235,.08);
    }

    .task-name {
        font-size: 17px;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.5;
        word-break: break-word;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .task-points {
        margin-top: 10px;
        font-weight: 700;
        color: #334155;
        font-size: 14px;
    }

    .task-priority {
        margin-top: 8px;
        display: inline-flex;
        padding: 8px 14px;
        border-radius: 30px;
        background: #eff6ff;
        color: #2563eb;
        font-weight: 700;
        font-size: 13px;
    }

    .summary-card {
        background: linear-gradient(135deg,#ffffff,#eff6ff);
        border-radius: 30px;
        padding: 35px;
        border: 1px solid #dbeafe;
    }

    .summary-line {
        margin-bottom: 18px;
        line-height: 1.8;
        color: #334155;
    }

        .summary-line strong {
            color: #0f172a;
        }

    .sprint-header-box {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(350px,1fr));
        gap: 25px;
    }

    .sprint-box {
        background: linear-gradient(135deg,#ffffff,#eff6ff);
        border-radius: 25px;
        padding: 25px;
        border: 1px solid #dbeafe;
    }

    .toast {
        position: fixed;
        right: 30px;
        bottom: 30px;
        background: #0f172a;
        color: white;
        padding: 15px 25px;
        border-radius: 15px;
        opacity: 0;
        transition: .3s;
        z-index: 999999;
    }

    .btn-primary,
    .btn-secondary,
    .btn-danger {
        border: none;
        padding: 10px 18px;
        border-radius: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: .2s;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg,#2563eb,#1d4ed8);
        color: white;
    }

    .btn-secondary {
        background: #e2e8f0;
        color: #0f172a;
    }

    .btn-danger {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
    }

        .btn-primary:hover,
        .btn-secondary:hover,
        .btn-danger:hover {
            transform: translateY(-2px);
        }

    .priority-alta {
        background: #fee2e2;
        color: #dc2626;
    }

    .priority-média {
        background: #fef9c3;
        color: #ca8a04;
    }

    .priority-baixa {
        background: #dcfce7;
        color: #16a34a;
    }

    .priority-sem {
        background: #e2e8f0;
        color: #475569;
    }

    .input-error {
        border: 2px solid #ef4444 !important;
        animation: shake .2s linear 2;
    }

    @@keyframes shake {

        0% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-4px);
        }

        50% {
            transform: translateX(4px);
        }

        75% {
            transform: translateX(-4px);
        }

        100% {
            transform: translateX(0);
        }
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.65);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 999999;
        padding: 20px;
    }

    .modal-box {
        width: 100%;
        max-width: 480px;
        background: white;
        border-radius: 28px;
        padding: 30px;
        position: relative;
        animation: modalShow .2s ease;
    }

    @@keyframes modalShow {

        from {
            transform: scale(.9);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .modal-title {
        font-size: 24px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 20px;
    }

    .modal-close {
        position: absolute;
        right: 18px;
        top: 18px;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: none;
        background: #f1f5f9;
        cursor: pointer;
        font-size: 18px;
    }

    .card-alta {
        border-left: 6px solid #dc2626;
        background: linear-gradient(135deg,#fff,#fef2f2);
    }

    .card-média {
        border-left: 6px solid #ca8a04;
        background: linear-gradient(135deg,#fff,#fefce8);
    }

    .card-baixa {
        border-left: 6px solid #16a34a;
        background: linear-gradient(135deg,#fff,#f0fdf4);
    }

    .card-sem {
        border-left: 6px solid #94a3b8;
    }

    .modal-task-name {
        margin-top: 15px;
        background: #f8fafc;
        border-radius: 18px;
        padding: 18px;
        font-weight: 700;
        color: #0f172a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    #health {
        display: none;
    }

    #health {
        visibility: hidden;
        height: 0;
    }

    .btn-salvando {
        animation: pulseSave .6s infinite alternate;
    }

    @@keyframes pulseSave {

        from {
            transform: scale(1);
        }

        to {
            transform: scale(1.06);
        }
    }

    .summary-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    .summary-header {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .summary-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        box-shadow: 0 10px 30px rgba(37,99,235,.28);
    }

    .summary-title {
        font-size: 24px;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
    }

    .summary-subtitle {
        margin-top: 6px;
        font-size: 13px;
        color: #64748b;
        font-weight: 500;
    }

    .summary-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-export {
        border: none;
        outline: none;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 22px;
        border-radius: 16px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s ease;
        position: relative;
        overflow: hidden;
    }

    .btn-export span {
        font-size: 18px;
    }

    .btn-pdf {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        box-shadow: 0 10px 24px rgba(239,68,68,.28);
    }

    .btn-excel {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        box-shadow: 0 10px 24px rgba(34,197,94,.28);
    }

    .btn-export:hover {
        transform:
            translateY(-3px)
            scale(1.02);
        filter: brightness(1.05);
    }

    .btn-export:active {
        transform: scale(.96);
    }

    .btn-export::before {
        content: "";
        position: absolute;
        top: 0;
        left: -120%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.25), transparent);
        transition: .6s;
    }

    .btn-export:hover::before {
        left: 120%;
    }

    .summary-container {
        background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(248,250,252,.98));
        border-radius: 28px;
        padding: 30px;
        border: 1px solid rgba(226,232,240,.9);
        box-shadow: 0 20px 45px rgba(15,23,42,.08);
        position: relative;
        overflow: hidden;
    }

    .summary-container::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 6px;
        background: linear-gradient(90deg, #2563eb, #22c55e, #f59e0b, #ef4444);
    }

    .summary-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        padding: 16px 18px;
        border-radius: 18px;
        margin-bottom: 12px;
        background: rgba(248,250,252,.95);
        border: 1px solid rgba(226,232,240,.9);
        transition: .22s ease;
    }

    .summary-line:hover {
        transform: translateX(5px);
        background: rgba(241,245,249,.95);
        border-color: rgba(59,130,246,.35);
        box-shadow: 0 10px 25px rgba(15,23,42,.06);
    }

    .summary-line strong {
        color: #0f172a;
        font-size: 14px;
    }

    .summary-line span {
        font-weight: 700;
        color: #2563eb;
    }

    .health-wrapper {
        margin-top: 22px;
    }

    .health-bar-bg {
        width: 100%;
        height: 18px;
        background: #e2e8f0;
        border-radius: 999px;
        overflow: hidden;
        position: relative;
    }

    .health-bar-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #22c55e, #16a34a);
        transition: width .4s ease;
    }

    .health-bar-fill::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(120deg, transparent, rgba(255,255,255,.4), transparent);
        animation: brilhoHealth 2.5s linear infinite;
    }

    @@keyframes brilhoHealth {

        from {
            transform: translateX(-100%);
        }

        to {
            transform: translateX(300%);
        }
    }

    @@media (max-width: 768px) {

        .summary-topbar {
            flex-direction: column;
            align-items: stretch;
        }

        .summary-actions {
            width: 100%;
        }

        .btn-export {
            flex: 1;
            justify-content: center;
        }

        .summary-line {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    .task-card {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
        backdrop-filter: blur(10px);
    }

        .task-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 40px rgba(15,23,42,.12);
        }

        .task-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient( 135deg, rgba(255,255,255,.12), transparent );
            pointer-events: none;
        }

    .task-name {
        font-size: 17px;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.4;
    }

    .task-points {
        margin-top: 12px;
        font-size: 14px;
        font-weight: 700;
        color: #2563eb;
    }

    .task-priority {
        margin-top: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .4px;
        text-transform: uppercase;
    }

    #toast {
        position: fixed;
        right: 28px;
        bottom: 28px;
        background: linear-gradient( 135deg, #0f172a, #1e293b );
        color: white;
        padding: 18px 24px;
        border-radius: 18px;
        font-weight: 700;
        box-shadow: 0 20px 40px rgba(15,23,42,.25);
        z-index: 999999;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity .35s ease, transform .35s ease;
        backdrop-filter: blur(12px);
    }

    .planning-header,
    .glass-card,
    .metric-card,
    .health-box,
    .task-column,
    .task-card,
    .sprint-box,
    .summary-container,
    .modal-box {
        border: 1.5px solid rgba(37, 99, 235, .18) !important;
    }

    .planning-header,
    .glass-card,
    .metric-card,
    .health-box,
    .task-column,
    .sprint-box,
    .summary-container,
    .modal-box {
        box-shadow: 0 0 0 1px rgba(37, 99, 235, .08), 0 12px 30px rgba(37, 99, 235,.08), 0 6px 12px rgba(0,0,0,.04);
    }

        .planning-header:hover,
        .glass-card:hover,
        .metric-card:hover,
        .health-box:hover,
        .task-column:hover,
        .sprint-box:hover,
        .summary-container:hover {
            border-color: rgba(37, 99, 235, .45);
            box-shadow: 0 0 0 1px rgba(37, 99, 235, .25), 0 18px 40px rgba(37, 99, 235,.12);
            transform: translateY(-2px);
            transition: .25s ease;
        }

    .planning-header {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(255,255,255,.92), rgba(248,250,255,.85));
        backdrop-filter: blur(28px);
        border-radius: 28px;
        padding: 40px;
        border: 1.5px solid rgba(37,99,235,.25);
        box-shadow: 0 20px 60px rgba(37,99,235,.12);
        transition: .3s ease;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

        .planning-header::before {
            content: "";
            position: absolute;
            inset: -50%;
            background: radial-gradient(circle, rgba(37,99,235,.10), transparent 60%);
            pointer-events: none;
        }

        .planning-header::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            height: 5px;
            width: 100%;
            background: linear-gradient(90deg, #2563eb, #7c3aed, #22c55e, #f59e0b);
        }

    .header-top {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .planning-title {
        font-size: 54px;
        font-weight: 900;
        background: linear-gradient(135deg, #2563eb, #7c3aed, #0f172a);

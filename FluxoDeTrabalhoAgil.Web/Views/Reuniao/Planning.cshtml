</style>

<div class="planning-wrapper">

    <div class="planning-header">

        <div class="header-top">
            <div class="planning-title">Sprint Planning</div>
            <div class="planning-subtitle">
                Planejamento completo da Sprint Scrum.
            </div>
        </div>

        <div class="top-actions">

            <div class="actions-left" style="flex: 1;">

                <div class="input-group sprint-select">
                    <label class="input-label">Selecionar Sprint</label>

                    <select id="filtroSprint" onchange="trocarSprint()">
                        <option value="">Nova Sprint</option>
                    </select>
                </div>

            </div>

            <div class="actions-right">

                <button class="btn-primary" onclick="novaSprint()">
                    🚀 Nova Sprint
                </button>

                <button class="btn-secondary" onclick="salvarPlanning()">
                    💾 Salvar Sprint
                </button>

            </div>

        </div>

    </div>

    <div class="sprint-header-box">

        <div class="sprint-box">

            <div class="input-group">

                <label class="input-label">
                    Nome da Sprint
                </label>

                <input type="text"
                       id="nomeSprint"
                       oninput="atualizarResumo()"
                       class="input"
                       placeholder="Ex: Sprint 15 - Módulo Financeiro">

            </div>

        </div>

        <div class="sprint-box">

            <div class="input-group">

                <label class="input-label">
                    Meta da Sprint
                </label>

                <textarea id="metaSprint"
                          oninput="atualizarResumo()"
                          placeholder="Ex: Entregar módulo financeiro completo com dashboard e relatórios."></textarea>

            </div>

        </div>

    </div>

    <div class="grid-3">

        <div class="metric-card">

            <div class="metric-title">
                Time Scrum
            </div>

            <div class="metric-number"
                 id="totalCapacidade">
                0h
            </div>

            <div class="metric-sub">
                Quantidade total de horas disponíveis da Sprint.
            </div>

            <div class="input-group"
                 style="margin-top:20px;">

                <label class="input-label">
                    Quantidade de Desenvolvedores
                </label>

                <input type="number"
                       min="0"
                       value="0"
                       id="qtdDevs"
                       class="input"
                       placeholder="Ex: 6"
                       oninput="calcularCapacidade()">

            </div>

            <div class="input-group">

                <label class="input-label">
                    Horas por Desenvolvedor
                </label>

                <input type="number"
                       min="0"
                       value="0"
                       id="horasDev"
                       class="input"
                       placeholder="Ex: 40"
                       oninput="calcularCapacidade()">

            </div>

        </div>

        <div class="metric-card">

            <div class="metric-title">
                Velocity da Sprint
            </div>

            <div class="metric-number"
                 id="velocityNumero">
                0 pts
            </div>

            <div class="metric-sub">
                Total de Story Points planejados.
            </div>

            <div class="input-group"
                 style="margin-top:20px;">

                <label class="input-label">
                    Velocity Esperada
                </label>

                <input type="number"
                       min="0"
                       value="0"
                       id="velocity"
                       class="input"
                       placeholder="Ex: 45"
                       oninput="atualizarResumo()">

            </div>

        </div>

        <div class="health-box">

            <div class="metric-title">
                Saúde Sprint
            </div>

            <div style="color:#475569;line-height:1.7;">

                A saúde mede o equilíbrio entre:
                capacidade do time,
                quantidade de pontos
                e risco da Sprint.

            </div>

            <div class="input-group"
                 style="margin-top:20px;">

                <input type="range"
                       min="0"
                       max="100"
                       value="70"
                       id="health"
                       class="health-range"
                       oninput="atualizarHealth()">

            </div>

            <div class="health-status"
                 id="healthTexto">
                🟢 Sprint saudável
            </div>

            <div style="margin-top:10px;color:#475569;">
                Pontos atuais:
                <strong id="healthAtual">70</strong>
            </div>

            <div style="margin-top:5px;color:#475569;">
                Faltam:
                <strong id="healthFalta">0</strong>
                pts para atingir a velocity.
            </div>

            <div class="health-progress">

                <div class="health-progress-bar"
                     id="healthBar"></div>

            </div>

        </div>

    </div>

    <div class="glass-card">

        <div class="section-title">
            ➕ Adicionar Item no Product Backlog
        </div>

        <div class="grid-3">

            <div class="input-group">

                <label class="input-label">
                    Nome da Task
                </label>

                <input type="text"
                       id="taskNome"
                       class="input"
                       placeholder="Ex: Criar dashboard financeiro">

            </div>

            <div class="input-group">

                <label class="input-label">
                    Story Points
                </label>

                <input type="number"
                       min="0"
                       id="taskPontos"
                       class="input"
                       placeholder="Ex: 8">

            </div>

            <div class="input-group">

                <label class="input-label">
                    Prioridade
                </label>

                <select id="taskPrioridade">

                <option value="Sem Prioridade" selected>
                    Sem Prioridade
                </option>

                <option value="Alta">
                    Alta
                </option>

                <option value="Média">
                    Média
                </option>

                <option value="Baixa">
                    Baixa
                </option>

            </select>

            </div>

        </div>

        <button class="btn-primary"
                onclick="adicionarTask()">
            ➕ Adicionar Task
        </button>

    </div>

    <div class="backlog-grid">

        <div class="task-column">

            <h3>
                📋 Product Backlog
            </h3>

            <div id="productBacklog"></div>

        </div>

        <div class="task-column">

            <h3>
                🚀 Sprint Backlog
            </h3>

            <div id="sprintBacklog"></div>

        </div>

    </div>

    <div class="summary-container">

        <div class="summary-topbar">

            <div class="summary-header">

                <div class="summary-icon">
                    🤖
                </div>

                <div>

                    <div class="summary-title">
                        Resumo da Sprint
                    </div>

                    <div class="summary-subtitle">
                        Indicadores inteligentes da sprint em tempo real
                    </div>

                </div>

            </div>

            <div class="summary-actions">

                <button class="btn-export btn-pdf"
                        onclick="exportarPDF()">

                    <span>📄</span>
                    Exportar PDF

                </button>

                <button class="btn-export btn-excel"
                        onclick="exportarExcel()">

                    <span>📊</span>
                    Exportar Excel

                </button>

            </div>

        </div>

        <div id="summary"></div>

    </div>

</div>

<div class="toast"
     id="toast">
</div>

<div class="modal-overlay"
     id="modalExcluir"
     onclick="fecharModal(event)">

    <div class="modal-box">

        <button class="modal-close"
                onclick="fecharModal()">
            ✕
        </button>

        <div class="modal-title">
            Confirmar exclusão
        </div>

        <div id="modalTexto"
             style="line-height:1.8;color:#475569;margin-bottom:25px;">
        </div>

        <div style="display:flex;gap:10px;justify-content:end;">

            <button class="btn-secondary"
                    onclick="fecharModal()">
                Cancelar
            </button>

            <button class="btn-danger"
                    onclick="confirmarExcluir()">
                Excluir
            </button>

        </div>

    </div>

</div>

<script>

    let backlog = [];

    let indexExcluir = -1;

    const API =
        "http://localhost:5228/api/planning";

    let sprintAtualId = 0;

    function mostrarToast(texto) {

        const toast =
            document.getElementById("toast");

        toast.innerText = texto;

        toast.style.opacity = "1";
        toast.style.transform = "translateY(0)";

        setTimeout(() => {

            toast.style.opacity = "0";
            toast.style.transform = "translateY(20px)";

        }, 2500);
    }


    function atualizarHealth() {

        const valor =
            parseInt(
                document.getElementById("health").value
            );

        document.getElementById(
            "healthAtual"
        ).innerText = valor;

        document.getElementById(
            "healthFalta"
        ).innerText = 100 - valor;

        document.getElementById(
            "healthBar"
        ).style.width = valor + "%";

        const texto =
            document.getElementById(
                "healthTexto"
            );

        if (valor >= 80)
            texto.innerHTML =
                "🟢 Sprint saudável";

        else if (valor >= 50)
            texto.innerHTML =
                "🟡 Sprint moderada";

        else
            texto.innerHTML =
                "🔴 Sprint em risco";

        atualizarResumo();
    }

    function calcularCapacidade() {

        const devs =
            parseInt(
                document.getElementById("qtdDevs").value
            ) || 0;

        const horas =
            parseInt(
                document.getElementById("horasDev").value
            ) || 0;

        const total =
            devs * horas;

        document.getElementById(
            "totalCapacidade"
        ).innerText = total + "h";

        atualizarResumo();
    }

    function adicionarTask() {

        const campoNome =
            document.getElementById("taskNome");

        const nome =
            campoNome.value.trim();

        const pontosCampo =
            document.getElementById("taskPontos").value;

        const prioridade =
            document.getElementById("taskPrioridade").value;

        campoNome.classList.remove("input-error");

        if (!nome) {

            campoNome.classList.add("input-error");

            mostrarToast(
                "O nome da task é obrigatório."
            );

            campoNome.focus();

            return;
        }

            const task = {

                nome,
                pontos: pontosCampo
                    ? parseInt(pontosCampo)
                    : 0,

                prioridade,
                naSprint: false
            };

        backlog.push(task);

        renderizarBacklogs();

        limparCamposTask();

        atualizarResumo();

        mostrarToast(
            "Task adicionada."
        );
    }

    function limparCamposTask() {

        document.getElementById(
            "taskNome"
        ).value = "";

        document.getElementById(
            "taskPontos"
        ).value = "";

        document.getElementById(
            "taskPrioridade"
        ).value = "Sem Prioridade";
    }

    function renderizarBacklogs() {

        const product =
            document.getElementById(
                "productBacklog"
            );

        const sprint =
            document.getElementById(
                "sprintBacklog"
            );

        product.innerHTML = "";
        sprint.innerHTML = "";

        backlog.forEach((task, index) => {

                let cardClasse =
                    "card-sem";

                let prioridadeClasse =
                    "priority-sem";

                if (task.prioridade === "Alta") {

                    prioridadeClasse = "priority-alta";
                    cardClasse = "card-alta";
                }

                else if (task.prioridade === "Média") {

                    prioridadeClasse = "priority-média";
                    cardClasse = "card-média";
                }

                else if (task.prioridade === "Baixa") {

                    prioridadeClasse = "priority-baixa";
                    cardClasse = "card-baixa";
                }

            const html = `

                    <div class="task-card ${cardClasse}">

                    <div class="task-name"
                         title="${task.nome}">
                        ${task.nome}
                    </div>

                    <div class="task-points">
                        ${task.pontos} Story Points
                    </div>

                    <div class="task-priority ${prioridadeClasse}">
                        ${task.prioridade}
                    </div>

                    <div style="margin-top:18px;display:flex;gap:8px;flex-wrap:wrap;">

                        <button class="btn-primary"
                                onclick="moverTask(${index})">

                            ${task.naSprint
                        ? "↩ Remover da Sprint"
                        : "🚀 Colocar na Sprint"}

                        </button>

                        <button class="btn-danger"
                                onclick="abrirModalExcluir(${index})">
                            🗑 Excluir
                        </button>

                    </div>

                </div>

            `;

            if (task.naSprint)
                sprint.innerHTML += html;
            else
                product.innerHTML += html;
        });

        atualizarResumo();
    }

    function moverTask(index) {

        backlog[index].naSprint =
            !backlog[index].naSprint;

        renderizarBacklogs();
    }

    function abrirModalExcluir(index) {

        indexExcluir = index;

        const nome =
            backlog[index].nome;

        document.getElementById(
            "modalTexto"
        ).innerHTML = `

            Deseja realmente excluir a task:

                <div class="modal-task-name"
             title="${nome}">
            ${nome}
        </div>

        `;

        document.getElementById(
            "modalExcluir"
        ).style.display = "flex";
    }

    function fecharModal(event) {

        if (
            event &&
            event.target.id !== "modalExcluir"
        )
            return;

        document.getElementById(
            "modalExcluir"
        ).style.display = "none";
    }

    function confirmarExcluir() {

        if (indexExcluir < 0)
            return;

        backlog.splice(indexExcluir, 1);

        renderizarBacklogs();

        fecharModal();

        mostrarToast(
            "Task removida."
        );
    }

    function removerTask(index) {

        backlog.splice(index, 1);

        renderizarBacklogs();

        mostrarToast(
            "Task removida."
        );
    }

    function atualizarResumo() {

        const nomeSprint =
            document.getElementById("nomeSprint").value;

        const metaSprint =
            document.getElementById("metaSprint").value;

        const qtdDevs =
            parseInt(
                document.getElementById("qtdDevs").value
            ) || 0;

        const horas =
            parseInt(
                document.getElementById("horasDev").value
            ) || 0;

        const velocity =
            parseInt(
                document.getElementById("velocity").value
            ) || 0;

        const sprintTasks =
            backlog.filter(x => x.naSprint);

        const pontos =
            sprintTasks.reduce((a, b) => {

                const valor =
                    parseInt(b.pontos);

                return a + (
                    isNaN(valor)
                        ? 0
                        : valor
                );

            }, 0);

        const capacidade =
            qtdDevs * horas;

        let health = 0;

        if (velocity > 0) {

            health =
                Math.min(
                    Math.max(
                        Math.round(
                            (pontos / velocity) * 100
                        ),
                        0
                    ),
                    100
                );
        }

        let healthTexto =
            "🔴 Sprint em risco";

        if (health >= 80)
            healthTexto =
                "🟢 Sprint saudável";

        else if (health >= 50)
            healthTexto =
                "🟡 Sprint moderada";

        document.getElementById(
            "health"
        ).value = health;

        document.getElementById(
            "healthAtual"
        ).innerText = pontos;

        document.getElementById(
            "healthFalta"
        ).innerText =
            velocity - pontos;

        const percentualBarra =
            velocity > 0
                ? (pontos / velocity) * 100
                : 0;

        document.getElementById(
            "healthBar"
        ).style.width =
            Math.min(percentualBarra, 100) + "%";

        document.getElementById(
            "healthTexto"
        ).innerHTML = healthTexto;

        document.getElementById(
            "velocityNumero"
        ).innerText = velocity + " pts";

        const falta = velocity - pontos;

        document.getElementById(
            "summary"
        ).innerHTML = `

            <div class="summary-line">
                <strong>Nome da Sprint:</strong>
                ${nomeSprint || "-"}
            </div>

            <div class="summary-line">
                <strong>Meta:</strong>
                ${metaSprint || "-"}
            </div>

            <div class="summary-line">
                <strong>Devs:</strong>
                ${qtdDevs}
            </div>

            <div class="summary-line">
                <strong>Horas por Dev:</strong>
                ${horas}
            </div>

            <div class="summary-line">
                <strong>Capacidade:</strong>
                ${capacidade} horas
            </div>

            <div class="summary-line">
                <strong>Velocity Esperada:</strong>
                ${velocity} pts
            </div>

            <div class="summary-line">
                <strong>Tasks na Sprint:</strong>
                ${sprintTasks.length}
            </div>

            <div class="summary-line">
                <strong>Pontos Utilizados:</strong>
                ${pontos} pts
            </div>

            <div class="summary-line">
                <strong>Health da Sprint:</strong>
                ${health}% (${healthTexto})
            </div>

            <div class="summary-line">
                <strong>Faltam:</strong>
                ${falta} pts para atingir a velocity
            </div>

        `;
    }

    function novaSprint() {

        sprintAtualId = 0;

        backlog = [];

        document.getElementById(
            "filtroSprint"
        ).value = "";

        document.getElementById(
            "nomeSprint"
        ).value = "";

        document.getElementById(
            "metaSprint"
        ).value = "";

        document.getElementById(
            "qtdDevs"
        ).value = 0;

        document.getElementById(
            "horasDev"
        ).value = 0;

        document.getElementById(
            "velocity"
        ).value = 0;

        document.getElementById(
            "taskPrioridade"
        ).value = "Sem Prioridade";

        renderizarBacklogs();

        calcularCapacidade();

        atualizarResumo();

        mostrarToast(
            "Nova Sprint iniciada."
        );
    }

    async function carregarSprints() {

        const response =
            await fetch(API);

        const dados =
            await response.json();

        const select =
            document.getElementById(
                "filtroSprint"
            );

        select.innerHTML = `

                <option value="">
                    Nova Sprint
                </option>

            `;

        dados.forEach(x => {

            select.innerHTML += `

                    <option value="${x.id}">
                        ${x.nomeSprint}
                    </option>

                `;
        });
    }

    async function trocarSprint() {

        const id =
            document.getElementById(
                "filtroSprint"
            ).value;

        if (!id) {

            novaSprint();

            return;
        }

        const response =
            await fetch(`${API}/${id}`);

        const sprint =
            await response.json();

        sprintAtualId =
            sprint.id;

        document.getElementById(
            "nomeSprint"
        ).value =
            sprint.nomeSprint || "";

        document.getElementById(
            "metaSprint"
        ).value =
            sprint.metaSprint || "";

        document.getElementById(
            "qtdDevs"
        ).value =
            sprint.qtdDevs || 0;

        document.getElementById(
            "horasDev"
        ).value =
            sprint.horasDev || 0;

        document.getElementById(
            "velocity"
        ).value =
            sprint.velocity || 0;

        backlog =
            sprint.backlog || [];

        renderizarBacklogs();

        calcularCapacidade();

        atualizarResumo();

        mostrarToast(
            "Sprint carregada."
        );
    }
   
    atualizarHealth();

    calcularCapacidade();

    atualizarResumo();

    carregarSprints();

    async function salvarPlanning() {

        const campoNomeSprint =
            document.getElementById("nomeSprint");

        const nomeSprint =
            campoNomeSprint.value.trim();

        campoNomeSprint.classList.remove("input-error");

        if (!nomeSprint) {

            campoNomeSprint.classList.add("input-error");

            mostrarToast(
                "Informe o nome da Sprint."
            );

            campoNomeSprint.focus();

            return;
        }

        const payload = {

            id: sprintAtualId,

            nomeSprint,

            metaSprint:
                document.getElementById("metaSprint").value,

            qtdDevs:
                parseInt(
                    document.getElementById("qtdDevs").value
                ) || 0,

            horasDev:
                parseInt(
                    document.getElementById("horasDev").value
                ) || 0,

            capacidade:
                (
                    parseInt(
                        document.getElementById("qtdDevs").value
                    ) || 0
                ) *
                (
                    parseInt(
                        document.getElementById("horasDev").value
                    ) || 0
                ),

            velocity:
                parseInt(
                    document.getElementById("velocity").value
                ) || 0,

            pontosSprint:
                backlog
                    .filter(x => x.naSprint)
                    .reduce((a, b) =>
                        a + (
                            parseInt(b.pontos) || 0
                        ), 0),

            health:
                parseInt(
                    document.getElementById("health").value
                ) || 0,

            backlog
        };

        const metodo =
            sprintAtualId > 0
                ? "PUT"
                : "POST";

        const url =
            sprintAtualId > 0
                ? `${API}/${sprintAtualId}`
                : API;

        const response =
            await fetch(url, {

                method: metodo,

                headers: {
                    "Content-Type": "application/json"
                },

                body: JSON.stringify(payload)
            });

        if (!response.ok) {

            mostrarToast(
                "Erro ao salvar Sprint."
            );

            return;
        }

        const resultado =
            await response.json();

        sprintAtualId =
            resultado.id;

        mostrarToast(
            "✅ Sprint salva com sucesso!"
        );

        const botaoSalvar =
            document.querySelector(
                '.btn-secondary[onclick="salvarPlanning()"]'
            );

        botaoSalvar.innerHTML =
            "✅ Salvo";

        botaoSalvar.classList.add(
            "btn-salvando"
        );

        setTimeout(() => {

            botaoSalvar.innerHTML =
                "💾 Salvar Sprint";

            botaoSalvar.classList.remove(
                "btn-salvando"
            );

        }, 2000);

        await carregarSprints();

        document.getElementById(
            "filtroSprint"
        ).value = sprintAtualId;
    }

    async function exportarPDF() {

        const {
            jsPDF
        } = window.jspdf;

        const doc =
            new jsPDF();

        const nomeSprint =
            document.getElementById(
                "nomeSprint"
            ).value || "-";

        const metaSprint =
            document.getElementById(
                "metaSprint"
            ).value || "-";

        const qtdDevs =
            parseInt(
                document.getElementById(
                    "qtdDevs"
                ).value
            ) || 0;

        const horas =
            parseInt(
                document.getElementById(
                    "horasDev"
                ).value
            ) || 0;

        const velocity =
            parseInt(
                document.getElementById(
                    "velocity"
                ).value
            ) || 0;

        const sprintTasks =
            backlog.filter(x => x.naSprint);

        const pontos =
            sprintTasks.reduce(
                (a, b) => {

                    const valor =
                        parseInt(b.pontos);

                    return a + (
                        isNaN(valor)
                            ? 0
                            : valor
                    );

                },
                0
            );

        const health =
            parseInt(
                document.getElementById(
                    "health"
                ).value
            );

        const dataAtual =
            new Date()
                .toLocaleString(
                    "pt-BR"
                );

        let y = 20;

        doc.setFillColor(37, 99, 235);

        doc.rect(
            0,
            0,
            210,
            40,
            "F"
        );

        doc.setTextColor(255,255,255);

        doc.setFontSize(28);

        doc.text(
            "SPRINT PLANNING",
            20,
            22
        );

        doc.setFontSize(11);

        doc.text(
            dataAtual,
            20,
            32
        );

        doc.setTextColor(15,23,42);

        y = 55;

        doc.setFontSize(22);

        doc.text(
            nomeSprint,
            20,
            y
        );

        y += 10;

        doc.setFontSize(12);

        const metaLinhas =
            doc.splitTextToSize(
                metaSprint,
                170
            );

        doc.text(
            metaLinhas,
            20,
            y
        );

        y += (
            metaLinhas.length * 7
        ) + 10;

        // CARDS

        const cards = [

            {
                titulo: "Devs",
                valor: qtdDevs
            },

            {
                titulo: "Capacidade",
                valor: `${ qtdDevs * horas } h`
            },

            {
                titulo: "Velocity",
                valor: `${ velocity } pts`
            },

            {
                titulo: "Story Points",
                valor: pontos
            }
        ];

        let x = 20;

        cards.forEach(card => {

            doc.setFillColor(
                248,
                250,
                252
            );

            doc.roundedRect(
                x,
                y,
                38,
                28,
                4,
                4,
                "F"
            );

            doc.setFontSize(10);

            doc.setTextColor(
                100,
                116,
                139
            );

            doc.text(
                card.titulo,
                x + 4,
                y + 9
            );

            doc.setFontSize(16);

            doc.setTextColor(
                37,
                99,
                235
            );

            doc.text(
                String(card.valor),
                x + 4,
                y + 20
            );

            x += 43;
        });

        y += 42;

        doc.setFontSize(16);

        doc.setTextColor(15,23,42);

        doc.text(
            "Saúde da Sprint",
            20,
            y
        );

        y += 10;

        doc.setFillColor(
            226,
            232,
            240
        );

        doc.roundedRect(
            20,
            y,
            170,
            10,
            5,
            5,
            "F"
        );

        let healthColor = [34,197,94];

        if (health < 80)
            healthColor = [234,179,8];

        if (health < 50)
            healthColor = [239,68,68];

        doc.setFillColor(
            healthColor[0],
            healthColor[1],
            healthColor[2]
        );

        doc.roundedRect(
            20,
            y,
            health * 1.7,
            10,
            5,
            5,
            "F"
        );

        y += 20;

        doc.setFontSize(20);

        doc.setTextColor(
            15,
            23,
            42
        );

        doc.text(
            "Tasks da Sprint",
            20,
            y
        );

        y += 12;

        sprintTasks.forEach((task, index) => {

            if (y > 260) {

                doc.addPage();

                y = 20;
            }

            let cor = [148,163,184];

            if (task.prioridade === "Alta")
                cor = [239,68,68];

            else if (task.prioridade === "Média")
                cor = [234,179,8];

            else if (task.prioridade === "Baixa")
                cor = [34,197,94];

            doc.setFillColor(
                255,
                255,
                255
            );

            doc.roundedRect(
                20,
                y,
                170,
                28,
                5,
                5,
                "F"
            );

            doc.setDrawColor(
                cor[0],
                cor[1],
                cor[2]
            );

            doc.setLineWidth(2);

            doc.line(
                20,
                y,
                20,
                y + 28
            );

            doc.setFontSize(12);

            doc.setTextColor(
                15,
                23,
                42
            );

            const nomeTask =
                doc.splitTextToSize(
                    task.nome,
                    120
                );

            doc.text(
                nomeTask,
                28,
                y + 10
            );

            doc.setFontSize(11);

            doc.setTextColor(
                cor[0],
                cor[1],
                cor[2]
            );

            doc.text(
                `${ task.pontos } pts`,
                150,
                y + 11
            );

            doc.text(
                task.prioridade,
                150,
                y + 20
            );

            y += 35;
        });

        doc.save(
            `${ nomeSprint }.pdf`
        );

        mostrarToast(
            "PDF exportado com sucesso."
        );
    }

    async function exportarExcel() {

        const nomeSprint =
            document.getElementById(
                "nomeSprint"
            ).value || "Sprint";

        const metaSprint =
            document.getElementById(
                "metaSprint"
            ).value || "-";

        const qtdDevs =
            parseInt(
                document.getElementById(
                    "qtdDevs"
                ).value
            ) || 0;

        const horas =
            parseInt(
                document.getElementById(
                    "horasDev"
                ).value
            ) || 0;

        const velocity =
            parseInt(
                document.getElementById(
                    "velocity"
                ).value
            ) || 0;

        const health =
            document.getElementById(
                "health"
            ).value;

        const sprintTasks =
            backlog.filter(x => x.naSprint);

        const productTasks =
            backlog.filter(x => !x.naSprint);

        const workbook =
            XLSX.utils.book_new();

        const resumoDados = [

            ["SPRINT PLANNING"],

            [],

            ["Nome Sprint", nomeSprint],

            ["Meta Sprint", metaSprint],

            ["Quantidade Devs", qtdDevs],

            ["Horas por Dev", horas],

            ["Capacidade", `${ qtdDevs * horas } h`],

            ["Velocity", `${ velocity } pts`],

            ["Health", `${ health } /100`],

            ["Tasks Sprint", sprintTasks.length],

            ["Tasks Backlog", productTasks.length]
        ];

        const wsResumo =
            XLSX.utils.aoa_to_sheet(
                resumoDados
            );

        wsResumo["!cols"] = [

            { wch: 30 },

            { wch: 70 }
        ];

        estilizarCabecalho(wsResumo, "A1", "1D4ED8");

        estilizarResumo(wsResumo);

        XLSX.utils.book_append_sheet(
            workbook,
            wsResumo,
            "Resumo"
        );

        const sprintDados = [

            [
                "Task",
                "Story Points",
                "Prioridade",
                "Status"
            ]
        ];

        sprintTasks.forEach(task => {

            sprintDados.push([

                task.nome,

                task.pontos,

                task.prioridade,

                "Sprint"
            ]);
        });

        if (!sprintTasks.length) {

            sprintDados.push([
                "Nenhuma task na Sprint",
                "-",
                "-",
                "-"
            ]);
        }

        const wsSprint =
            XLSX.utils.aoa_to_sheet(
                sprintDados
            );

        wsSprint["!cols"] = [

            { wch: 60 },

            { wch: 18 },

            { wch: 20 },

            { wch: 20 }
        ];

        estilizarTabela(wsSprint, sprintDados);
        wsSprint["A1"].s = wsSprint["A1"].s || {};
        wsSprint["A1"].s.fill = { fgColor: { rgb: "7C3AED" } };
        wsSprint["A1"].s.font = { bold: true, color: { rgb: "FFFFFF" } };

        XLSX.utils.book_append_sheet(
            workbook,
            wsSprint,
            "Sprint Backlog"
        );

        const backlogDados = [

            [
                "Task",
                "Story Points",
                "Prioridade",
                "Status"
            ]
        ];

        productTasks.forEach(task => {

            backlogDados.push([

                task.nome,

                task.pontos,

                task.prioridade,

                "Backlog"
            ]);
        });

        if (!productTasks.length) {

            backlogDados.push([
                "Nenhuma task no backlog",
                "-",
                "-",
                "-"
            ]);
        }

        const wsBacklog =
            XLSX.utils.aoa_to_sheet(
                backlogDados
            );

        wsBacklog["!cols"] = [

            { wch: 60 },

            { wch: 18 },

            { wch: 20 },

            { wch: 20 }
        ];

        estilizarTabela(wsBacklog, backlogDados);
        wsBacklog["A1"].s = wsBacklog["A1"].s || {};
        wsBacklog["A1"].s.fill = { fgColor: { rgb: "16A34A" } };
        wsBacklog["A1"].s.font = { bold: true, color: { rgb: "FFFFFF" } };

        XLSX.utils.book_append_sheet(
            workbook,
            wsBacklog,
            "Product Backlog"
        );
        
        XLSX.writeFile(
            workbook,
            `${nomeSprint}.xlsx`
        );

        mostrarToast(
            "Excel exportado com visual profissional."
        );
    }

    function estilizarCabecalho(sheet, celula, cor = "2563EB") {

        sheet[celula].s = {

            font: {
                bold: true,
                sz: 22,
                color: { rgb: "FFFFFF" }
            },

            fill: {
                fgColor: { rgb: cor }
            },

            alignment: {
                horizontal: "center",
                vertical: "center"
            }
        };

        sheet["!merges"] = [
            {
                s: { r: 0, c: 0 },
                e: { r: 0, c: 1 }
            }
        ];
    }

    function estilizarResumo(sheet) {

        const range =
            XLSX.utils.decode_range(
                sheet["!ref"]
            );

        for (
            let R = 2;
            R <= range.e.r;
            ++R
        ) {

            const cellA =
                XLSX.utils.encode_cell({
                    r: R,
                    c: 0
                });

            const cellB =
                XLSX.utils.encode_cell({
                    r: R,
                    c: 1
                });

            if (sheet[cellA]) {

                sheet[cellA].s = {

                    font: {
                        bold: true,
                        color: {
                            rgb: "0F172A"
                        }
                    },

                    fill: {
                        fgColor: {
                            rgb: "DBEAFE"
                        }
                    },

                    border: bordaPadrao(),

                    alignment: {
                        vertical: "center"
                    }
                };
            }

            if (sheet[cellB]) {

                sheet[cellB].s = {

                    border: bordaPadrao(),

                    alignment: {
                        wrapText: true,
                        vertical: "center"
                    }
                };
            }
        }
    }

    function estilizarTabela(sheet, dados) {

        const range =
            XLSX.utils.decode_range(
                sheet["!ref"]
            );

        for (
            let R = 0;
            R <= range.e.r;
            ++R
        ) {

            for (
                let C = 0;
                C <= range.e.c;
                ++C
            ) {

                const cell =
                    XLSX.utils.encode_cell({
                        r: R,
                        c: C
                    });

                if (!sheet[cell])
                    continue;

                if (R === 0) {

                    sheet[cell].s = {

                        font: {
                            bold: true,
                            color: {
                                rgb: "FFFFFF"
                            }
                        },

                        fill: {
                            fgColor: {
                                rgb: "2563EB"
                            }
                        },

                        border: bordaPadrao(),

                        alignment: {
                            horizontal: "center",
                            vertical: "center"
                        }
                    };
                }

                else {

                    let cor =
                        "FFFFFF";

                    const prioridade =
                        dados[R][2];

                    if (prioridade === "Alta")
                        cor = "FEE2E2";

                    else if (prioridade === "Média")
                        cor = "FEF9C3";

                    else if (prioridade === "Baixa")
                        cor = "DCFCE7";

                    sheet[cell].s = {

                        fill: {
                            fgColor: {
                                rgb: cor
                            }
                        },

                        border: bordaPadrao(),

                        alignment: {
                            vertical: "center",
                            wrapText: true
                        }
                    };
                }
            }
        }

        sheet["!autofilter"] = {

            ref: sheet["!ref"]
        };
    }

    function bordaPadrao() {

        return {

            top: {
                style: "thin",
                color: {
                    rgb: "CBD5E1"
                }
            },

            bottom: {
                style: "thin",
                color: {
                    rgb: "CBD5E1"
                }
            },

            left: {
                style: "thin",
                color: {
                    rgb: "CBD5E1"
                }
            },

            right: {
                style: "thin",
                color: {
                    rgb: "CBD5E1"
                }
            }
        };
    }

    window.onload = async () => {

        atualizarHealth();

        calcularCapacidade();

        atualizarResumo();

        await carregarSprints();
    };
</script>